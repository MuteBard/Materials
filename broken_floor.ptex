     vec3 c = $in( uv + vec2( float(i), float(j)) * offset / 100.0);\n            m[0] += c;\n            s[0] += c * c;\n        }\n    }\n\t\n\tfor (int j = -int(radius); j <= 0; ++j)  {\n        for (int i = 0; i <= int(radius); ++i)  {\n            vec3 c = $in( uv + vec2( float(i), float(j)) * offset / 100.0);\n            m[1] += c;\n            s[1] += c * c;\n        }\n    }\n\n    for (int j = 0; j <= int(radius); ++j)  {\n        for (int i = 0; i <= int(radius); ++i)  {\n            vec3 c = $in( uv + vec2( float(i), float(j)) * offset / 100.0);\n            m[2] += c;\n            s[2] += c * c;\n        }\n    }\n\n    for (int j = 0; j <= int(radius); ++j)  {\n        for (int i = -int(radius); i <= 0; ++i)  {\n            vec3 c = $in( uv + vec2( float(i), float(j)) * offset / 100.0);\n            m[3] += c;\n            s[3] += c * c;\n        }\n    }\n\t\n    float min_sigma2 = 1e+2;\n    for (int k = 0; k < 4; ++k) {\n        m[k] /= n;\n        s[k] = abs(s[k] / n - m[k] * m[k]);\n\n        float sigma2 = s[k].r + s[k].g + s[k].b;\n        if (sigma2 < min_sigma2) {\n            min_sigma2 = sigma2;\n            color = vec3(m[k]);\n        }\n    }\n\treturn color;\n}","name":"Kuwahara Filter","outputs":[{"rgb":"$(name)_kuwahara($uv, $radius, $offset)","type":"rgb"}],"parameters":[{"control":"None","default":4,"label":"Iterations","max":10,"min":1,"name":"radius","step":1,"type":"float"},{"control":"None","default":0.01,"label":"Offset","max":1,"min":0,"name":"offset","step":0.01,"type":"float"}]}},{"name":"blend2_14","type":"blend2","parameters":{"blend_type1":0,"amount1":1},"node_position":{"x":1440.119019,"y":-1147.175659},"seed_int":0,"generic_size":1},{"name":"colorize_3","type":"colorize","parameters":{"gradient":{"type":"Gradient","points":[{"pos":0,"r":0.278778,"g":0.319151,"b":0.351562,"a":1},{"pos":1,"r":0.558594,"g":0.527602,"b":0.519318,"a":1}],"interpolation":1}},"node_position":{"x":44.310886,"y":-1284.337769},"seed_int":0},{"name