,"g":1.0,"r":1.0,"type":"Color"}},"seed_int":0,"shortdesc":"A grid of 16 colors","type":"graph"},{"name":"sdpolygon_2","node_position":{"x":25640.0,"y":2720.0},"parameters":{"polygon":{"points":[{"x":0.427864521741867,"y":0.298979669809341},{"x":0.366636574268341,"y":0.275812327861786},{"x":0.307063400745392,"y":0.26257386803627},{"x":0.267847210168839,"y":0.25957316160202},{"x":0.264038354158401,"y":0.295670062303543},{"x":0.270657598972321,"y":0.36020764708519},{"x":0.293824940919876,"y":0.423090398311615},{"x":0.328575938940048,"y":0.471079915761948},{"x":0.374910622835159,"y":0.51079535484314},{"x":0.421245276927948,"y":0.543891549110413},{"x":0.472544401884079,"y":0.562094449996948},{"x":0.520533859729767,"y":0.567058861255646},{"x":0.552242457866669,"y":0.56596040725708},{"x":0.560249328613281,"y":0.524033844470978},{"x":0.556939661502838,"y":0.454531818628311},{"x":0.532117545604706,"y":0.391649037599564},{"x":0.484874725341797,"y":0.337117254734039}],"type":"Polygon"}},"seed_int":0,"type":"sdpolygon"},{"name":"sdpolygon","node_position":{"x":25640.0,"y":3700.0},"parameters":{"polygon":{"points":[{"x":0.738879799842834,"y":1.00426268577576},{"x":0.678010165691376,"y":0.966358065605164},{"x":0.648239552974701,"y":1.01429319381714}],"type":"Polygon"}},"seed_int":0,"type":"sdpolygon"},{"name":"sdpolygon_4","node_position":{"x":25640.0,"y":3780.0},"parameters":{"polygon":{"points":[{"x":1.03222763538361,"y":0.640238106250763},{"x":1.00280749797821,"y":0.747105300426483},{"x":0.984883785247803,"y":0.714323580265045},{"x":0.965777337551117,"y":0.683899164199829}],"type":"Polygon"}},"seed_int":0,"type":"sdpolygon"},{"color":{"a":1.0,"b":0.0,"g":0.0,"r":0.0,"type":"Color"},"name":"comment","node_position":{"x":23640.0,"y":760.0},"parameters":{},"seed_int":0,"size":{"x":720.0,"y":360.0},"text":"Double click to inspect the node group (which is made of other node groups). Basically, it uses polycurve nodes to determine individual paths of bricks, applies a thickness representing the brick's width, and then repeats a constant gradient along the paths - a small black column (representing the gap between bricks) and the remainder white column (representing the brick itself).\n\nThis does most of the heavy lifting in creating the brick pattern, but requires some adjustments in the next two segments.","title":"Node Group: Creating tiles using paths","type":"comment"},{"color":{"a":1.0,"b":0.0,"g":0.0,"r":0.0,"type":"Color"},"name":"comment_2","node_position":{"x":24420.0,"y":760.0},"parameters":{},"seed_int":0,"size":{"x":1440.0,"y":1320.0},"text":"Using sdPolygon and curve nodes to add a few more bricks and fix some lineworks. ","title":"Final adjustments for the mask","type":"comment"},{"color":{"a":1.0,"b":0.0,"g":0.0,"r":0.0,"type":"Color"},"name":"comment_3","node_position":{"x":26180.0,"y":620.0},"parameters":{},"seed_int":0,"size":{"x":1155.0,"y":545.0},"text":"","title":"Mirroring and adding final lines.","type":"comment"},{"color":{"a":1.0,"b":0.0,"g":0.0,"r":0.0,"type":"Color"},"name":"comment_4","node_position":{"x":25600.0,"y":2180.0},"parameters":{},"seed_int":0,"size":{"x":740.0,"y":1700.0},"text":"","title":"Creating masks for the three colors of bricks.","type":"comment"},{"color":{"a":1.0,"b":0.0,"g":0.0,"r":0.0,"type":"Color"},"name":"comment_5","node_position":{"x":26538.0,"y":2168.0},"parameters":{},"seed_int":0,"size":{"x":504.0,"y":825.0},"text":"","title":"Mirroring","type":"comment"},{"name":"reroute","node_position":{"x":27540.0,"y":2340.0},"parameters":{"preview":0.0},"seed_int":0,"type":"reroute"},{"name":"reroute_5","node_position":{"x":27540.0,"y":2420.0},"parameters":{"preview":0.0},"seed_int":0,"type":"reroute"},{"name":"reroute_12","node_position":{"x":27560.0,"y":2440.0},"parameters":{"preview":0.0},"seed_int":0,"type":"reroute"},{"color":{"a":1.0,"b":0.0,"g":0.0,"r":0.0,"type":"Color"},"name":"comment_6","node_position":{"x":27500.0,"y":1980.0},"parameters":{},"seed_int":0,"size":{"x":760.0,"y":1000.0},"text":"Using the previous masks, individual bricks are defined using \"fill from colors\" and \"fill to UV\". Then, a 16 (4x4) color node group (sampled 16 colors from a reference image), then applied randomly to the mask. This creates a more realistic variability ","title":"Applying the three colros to the bricks","type":"comment"},{"color":{"a":1.0,"b":0.0,"g":0.0,"r":0.0,"type":"Color"},"name":"comment_7","node_position":{"x":28980.0,"y":1960.0},"parameters":{},"seed_int":0,"size":{"x":340.0,"y":420.0},"text":"","title":"Dilating the colors to fill the gaps","type":"comment"},{"color":{"a":1.0,"b":0.0,"g":0.0,"r":0.0,"type":"Color"},"name":"comment_8","node_position":{"x":30380.0,"y":2420.0},"parameters":{},"seed_int":0,"size":{"x":1440.0,"y":360.0},"text":"","title":"Some marbling patterns, placed on a few tiles","type":"comment"},{"color":{"a":1.0,"b":0.0,"g":0.0,"r":0.0,"type":"Color"},"name":"comment_9","node_position":{"x":28440.0,"y":220.0},"parameters":{},"seed_int":0,"size":{"x":2054.0,"y":686.0},"text":"","title":"Base stone texture","type":"comment"},{"color":{"a":1.0,"b":0.0,"g":0.0,"r":0.0,"type":"Color"},"name":"comment_10","node_position":{"x":30620.0,"y":580.0},"parameters":{},"seed_int":0,"size":{"x":1014.0,"y":361.0},"text":"","title":"Lines randomly placed on some tiles","type":"comment"},{"color":{"a":1.0,"b":0.0,"g":0.0,"r":0.0,"type":"Color"},"name":"comment_11","node_position":{"x":31920.0,"y":1820.0},"parameters":{},"seed_int":0,"size":{"x":2180.0,"y":800.0},"text":"","title":"Finalizing the Albedo Map, applying details and blending things","type":"comment"},{"color":{"a":1.0,"b":0.0,"g":0.0,"r":0.0,"type":"Color"},"name":"comment_12","node_position":{"x":28618.0,"y":1168.0},"parameters":{},"seed_int":0,"size":{"x":800.0,"y":260.0},"text":"","title":"Dilate to give bricks some depth, then multiwarp on \"min\" mode to add some chips and weathering","type":"comment"},{"name":"reroute_15","node_position":{"x":32440.0,"y":940.0},"parameters":