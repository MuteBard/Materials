le described as a signed distance function","name":"sdPlane","outputs":[{"longdesc":"The generated signed distance function","sdf2d":"dot($uv-vec2($x,$y)-0.5,normalize(vec2(-sin($a*0.017453),cos($a*0.017453)))) * ($inv ? -1.0 : 1.0)","shortdesc":"Output","type":"sdf2d"}],"parameters":[{"control":"Radius1.a","default":0.5,"label":"Rad","max":360,"min":0,"name":"a","step":0.001,"type":"float"},{"control":"P1.x","default":0.5,"label":"X","max":1,"min":0,"name":"x","step":0.1,"type":"float"},{"control":"P1.y","default":0.5,"label":"Y","max":1,"min":0,"name":"y","step":0.1,"type":"float"},{"default":false,"label":"Invert","name":"inv","type":"boolean"}],"shortdesc":"sdBox"}},{"name":"sdannularshape_7","type":"sdannularshape","parameters":{"r":0.003,"ripples":1},"node_position":{"x":420,"y":520},"seed_int":0},{"name":"sdline2_6","type":"sdline2","parameters":{"ax":-0.0533,"ay":0,"bx":0.0236,"by":0,"r":0.0189},"node_position":{"x":180,"y":500},"seed_int":0},{"name":"shader_10","type":"shader","parameters":{"ax":-0.163125,"ay":-0.1275,"bx":0.140625,"by":-0.12375,"pts":6,"lr":0.003,"r":0.01,"il":false,"id":true},"node_position":{"x":820,"y":-200},"seed_int":0,"shader_model":{"code":"","global":"float dotted(vec2 uv, vec2 a, vec2 b, int pts, float r, float lr, bool il, bool id)\n{\n\tfloat res = 1.0;\n\t\n\tif(id) {\n\t\tfor(int i = 0; i <= pts; i++)\n\t\t{\n\t\t\tfloat c = distance(uv,mix(a,b,float(i)/float(pts)));\n\t\t\tres = min(res, c);\n\t\t}\n\t}\n\n\tfloat l = sdLine(uv, a, b).x-lr;\n\tl = max(l, r-res);\n\tif(!il) l = 1.0;\n\tres = min(l, abs(r-res)-lr);\n\treturn res;\n}","includes":["sdline2"],"inputs":[],"instance":"","name":"sdLinePointsOption","outputs":[{"sdf2d":"dotted($uv-0.5,vec2($ax,$ay),vec2($bx,$by),int($pts-1.0),$r,$lr, $il, $id)","type":"sdf2d"}],"parameters":[{"control":"P1.x","default":0.5,"label":"A X","max":1,"min":0,"name":"ax","step":0.1,"type":"float"},{"control":"P1.y","default":0.5,"label":"A Y","max":1,"min":0,"name":"ay","step":0.1,"type":"fl