del":{"code":"","global":"float dotted(vec2 uv, vec2 a, vec2 b, int pts, float r, float lr, bool il, bool id)\n{\n\tfloat res = 1.0;\n\t\n\tif(id) {\n\t\tfor(int i = 0; i <= pts; i++)\n\t\t{\n\t\t\tfloat c = distance(uv,mix(a,b,float(i)/float(pts)));\n\t\t\tres = min(res, c);\n\t\t}\n\t}\n\n\tfloat l = sdLine(uv, a, b).x-lr;\n\tl = max(l, r-res);\n\tif(!il) l = 1.0;\n\tres = min(l, abs(r-res)-lr);\n\treturn res;\n}","includes":["sdline2"],"inputs":[],"instance":"","name":"sdLinePointsOption","outputs":[{"sdf2d":"dotted($uv-0.5,vec2($ax,$ay),vec2($bx,$by),int($pts-1.0),$r,$lr, $il, $id)","type":"sdf2d"}],"parameters":[{"control":"P1.x","default":0.5,"label":"A X","max":1,"min":0,"name":"ax","step":0.1,"type":"float"},{"control":"P1.y","default":0.5,"label":"A Y","max":1,"min":0,"name":"ay","step":0.1,"type":"float"},{"control":"P2.x","default":0.5,"label":"B X","max":1,"min":0,"name":"bx","step":0.1,"type":"float"},{"control":"P2.y","default":0.5,"label":"B Y","max":1,"min":0,"name":"by","step":0.1,"type":"float"},{"control":"None","default":0.5,"label":"Count","max":32,"min":2,"name":"pts","step":1,"type":"float"},{"control":"None","default":0.5,"label":"Radius","max":1,"min":0,"name":"lr","step":0.1,"type":"float"},{"control":"None","default":0.5,"label":"Dot Radius","max":1,"min":0,"name":"r","step":0.1,"type":"float"},{"default":true,"label":"Line?","name":"il","type":"boolean"},{"default":true,"label":"Dot?","name":"id","type":"boolean"}]}},{"name":"shader_3","type":"shader","parameters":{"ax":0.156995,"ay":-0.242487,"bx":0.150777,"by":-0.139896,"pts":2,"lr":0.003,"r":0.01,"il":false,"id":true},"node_position":{"x":713.346069,"y":-466.694519},"seed_int":0,"shader_model":{"code":"","global":"float dotted(vec2 uv, vec2 a, vec2 b, int pts, float r, float lr, bool il, bool id)\n{\n\tfloat res = 1.0;\n\t\n\tif(id) {\n\t\tfor(int i = 0; i <= pts; i++)\n\t\t{\n\t\t\tfloat c = distance(uv,mix(a,b,float(i)/float(pts)));\n\t\t\tres = min(res, c);\n\t\t}\n\t}\n\n\tfloat l = sdLine(uv, a, b).x-lr;\n\tl = max(l, r-res);\n\tif(!il) l = 1.0;\n\tres = min(l, abs(r-res)-lr);\n\treturn res;\n}","includes":["sdline2"],"inputs":[],"instance":"","name":"sdLinePointsOption","outputs":[{"sdf2d":"dotted($uv-0.5,vec2($ax,$ay),vec2($bx,$by),int($pts-1.0),$r,$lr, $il, $id)","type":"sdf2d"}],"parameters":[{"control":"P1.x","default":0.5,"label":"A X","max":1,"min":0,"name":"ax","step":0.1,"type":"float"},{"control":"P1.y","default":0.5,"label":"A Y","max":1,"min":0,"name":"ay","step":0.1,"type":"float"},{"control":"P2.x","default":0.5,"label":"B X","max":1,"min":0,"name":"bx","step":0.1,"type":"float"},{"control":"P2.y","default":0.5,"label":"B Y","max":1,"min":0,"name":"by","step":0.1,"type":"float"},{"control":"None","default":0.5,"label":"Count","max":32,"min":2,"name":"pts","step":1,"type":"float"},{"control":"None","default":0.5,"label":"Radius","max":1,"min":0,"name":"lr","step":0.1,"type":"float"},{"control":"None","default":0.5,"label":"Dot Radius","max":1,"min":0,"name":"r","step":0.1,"type":"float"},{"default":true,"label":"Line?","name":"il","type":"boolean"},{"default":true,"label":"Dot?","name":"id","type":"boolean"}]}},{"name":"buffer_2","type":"buffer","parameters":{"size":10},"node_position":{"x":1380.346069,"y":-738.694519},"seed_int":0,"version":1},{"name":"shader_1","type":"shader","parameters":{"ax":0,"ay":0.0527,"bx":0,"by":-0.0175,"ra":0.1651,"rb":0.1131},"node_position":{"x":2409.649902,"y":-681.644958},"seed_int":0,"shader_model":{"code":"","global":"float sdTrapezoid(in vec2 p, in vec2 a, in vec2 b, in float ra, float rb)\n{\n    vec2 pa = p - a;\n    vec2 ba = b - a;\n    float baba = dot(ba, ba);\n    float x = abs(dot(vec2(-pa.y, pa.x), ba)) / sqrt(baba);\n    float paba = dot(pa, ba) / baba;\n    float rba = rb - ra;\n    float cax = max(0.0, x - ((paba < 0.5) ? ra : rb));\n    float cay = abs(paba - 0.5) - 0.5;\n    float f = clamp((rba*(x - ra) + paba * baba) / (rba * rba + baba), 0.0, 1.0);\n    float cbx = x - ra - f * rba;\n    float cby = paba - f;\n    return sign(max(cbx,cay)) * sqrt(min(cax*cax + cay * cay*baba, cbx*cbx + cby * cby*baba));\n}","inputs":[],"instance":"","name":"sdTrapezoid","outputs":[{"sdf2d":"sdTrapezoid($uv,vec2($ax,$ay)+.5,vec2($bx,$by)+.5,$ra,$rb)","type":"sdf2d"}],"parameters":[{"control":"P1.x","default":0.45,"label":"A X","max":1,"min":0,"name":"ax","step":0.01,"type":"float"},{"control":"P1.y","default":0,"label":"A Y","max":1,"min":0,"name":"ay","step":0.01,"type":"float"},{"control":"P2.x","default":-0.45,"label":"B X","max":1,"min":0,"name":"bx","step":0.01,"type":"float"},{"control":"P2.y","default":0,"label":"B Y","max":1,"min":0,"name":"by","step":0.01,"type":"float"},{"control":"None","default":0.15,"label":"Radius A","max":1,"min":0,"name":"ra","step":0.01,"type":"float"},{"control":"None","default":0.25,"label":"Radius B","max":1,"min":0,"name":"rb","step":0.01,"type":"float"}]}},{"name":"sdtranslate","type":"sdtranslate","parameters":{"x":0,"y":-0.0841},"node_position":{"x":2762.650146,"y":-712.645081},"seed_int":0},{"name":"sdboolean_4","type":"sdboolean","parameters":{"op":2},"node_position":{"x":2732.650146,"y":-564.64502},"seed_int":0},{"name":"sdannularshape_2","type":"sdannularshape","parameters":{"r":0.003,"ripples":1},"node_position":{"x":2982.650146,"y":-710.64502},"seed_int":0},{"name":"sdbox_2","type":"shader","parameters":{"a":-0,"x":0,"y":-0.063,"inv":false},"node_position":{"x":2422.650146,"y":-441.64502},"seed_int":0,"shader_model":{"code":"","global":"","inputs":[],"instance":"","longdesc":"A rectangle described as a signed distance function","name":"sdPlane","outputs":[{"longdesc":"The generated signed distance function","sdf2d":"dot($uv-vec2($x,$y)-0.5,normalize(vec2(-sin($a*0.017453),cos($a*0.017453)))) * ($inv ? -1.0 : 1.0)","shortdesc":"Output","type":"sdf2d"}],"parameters":[{"control":"Radius1.a","default":0.5,"label":"Rad","max":360,"min":0,"name":"a","step":0.001,"type":"float"},{"control":"P1.x","default":0.5,"labe