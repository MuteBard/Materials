otate":0,"scale":0,"value":0,"variations":false},"node_position":{"x":1060,"y":-360},"seed_int":0},{"name":"transform2","type":"transform2","parameters":{"translate_x":-0.09245,"translate_y":0.25725,"rotate":0,"scale_x":1,"scale_y":1,"mode":0},"node_position":{"x":1331.743774,"y":-410.232574},"seed_int":0,"generic_size":1},{"name":"tones_range","type":"tones_range","parameters":{"value":0.53,"width":0.55,"contrast":1,"invert":false},"node_position":{"x":1360,"y":0},"seed_int":0},{"name":"math_2","type":"math","parameters":{"op":2,"default_in1":0,"default_in2":0,"clamp":false},"node_position":{"x":1200,"y":-500},"seed_int":0},{"name":"transform2_2","type":"transform2","parameters":{"translate_x":0.0032,"translate_y":0.15275,"rotate":0,"scale_x":1,"scale_y":1,"mode":0},"node_position":{"x":1476.980347,"y":-487.15271},"seed_int":0,"generic_size":1},{"name":"mirror_2","type":"mirror","parameters":{"direction":0,"offset":0,"flip_sides":true},"node_position":{"x":1440,"y":-600},"seed_int":0},{"name":"transform2_3","type":"transform2","parameters":{"translate_x":-0.0032,"translate_y":0,"rotate":0,"scale_x":1,"scale_y":1,"mode":0},"node_position":{"x":1500,"y":-260},"seed_int":0,"generic_size":1},{"name":"sdshow_3","type":"sdshow","parameters":{"bevel":0,"base":0},"node_position":{"x":1940,"y":-200},"seed_int":0},{"name":"transform2_4","type":"transform2","parameters":{"translate_x":0,"translate_y":0.00415,"rotate":0,"scale_x":0.25,"scale_y":1,"mode":0},"node_position":{"x":1660,"y":-460},"seed_int":0,"generic_size":1},{"name":"sdboolean_2","type":"sdboolean","parameters":{"op":0},"node_position":{"x":1860,"y":-40},"seed_int":0},{"name":"runes_2","type":"shader","parameters":{"columns":1,"rows":4,"radius":0.025},"node_position":{"x":1600,"y":0},"seed_int":2658787584,"shader_model":{"code":"","global":"float ThickLine(vec2 uv, vec2 posA, vec2 posB)\n{\n\treturn sdLine(uv, posA, posB).x;\n}\n\n// makes a rune in the 0..1 uv space. Seed is which rune to draw.\n// passes back gray in x and derivates for lighting in yz\nfloat Rune(vec2 uv, float s) {\n\tfloat finalLine = 1.0;\n\tvec2 seed = floor(uv)-rand2(vec2(s));\n\tuv = fract(uv);\n\tfor (int i = 0; i < 4; i++)\t// number of strokes\n\t{\n\t\tvec2 posA = rand2(floor(seed+0.5));\n\t\tvec2 posB = rand2(floor(seed+1.5));\n\t\tseed += 2.0;\n\t\t// expand the range and mod it to get a nicely distributed random number - hopefully. :)\n\t\tposA = fract(posA * 128.0);\n\t\tposB = fract(posB * 128.0);\n\t\t// each rune touches the edge of its box on all 4 sides\n\t\tif (i == 0) posA.y = 0.0;\n\t\tif (i == 1) posA.x = 0.999;\n\t\tif (i == 2) posA.x = 0.0;\n\t\tif (i == 3) posA.y = 0.999;\n\t\t// snap the random line endpoints to a grid 2x3\n\t\tvec2 snaps = vec2(2.0, 3.0);\n\t\tposA = (floor(posA * snaps) + 0.5) / snaps;\t// + 0.5 to center it in a grid cell\n\t\tposB = (floor(posB * snaps) + 0.5) / snaps;\n\t\t//if (distance(posA, posB) < 0.0001) continue;\t// eliminate dots.\n\t\t// Dots (degenerate lines) are not cross-GPU safe without adding 0.001 - divide by 0 error.\n\t\tfinalLine = min(finalLine, ThickLine(uv, posA, posB + 0.001));\n\t}\n\treturn finalLine;\n}\n\n\n","includes":["sdline2"],"inputs":[],"instance":"","longdesc":"Generates a grid filled with random runes","name":"sdRunes","outputs":[{"longdesc":"A greyscale image showing random runes.","sdf2d":"Rune(vec2($columns, $rows)*$uv, float($seed))-$radius","shortdesc":"Output","type":"sdf2d"}],"parameters":[{"control":"None","default":0,"label":"Size X","longdesc":"The number of columns of the grid","max":32,"min":2,"name":"columns","shortdesc":"Size.x","step":1,"type":"float"},{"control":"None","default":0,"label":"Size Y","longdesc":"The number of rows of the grid","max":32,"min":2,"name":"rows","shortdesc":"Size.y","step":1,"type":"float"},{"control":"None","default":0.01,"label":"Radius","max":1,"min":0,"name":"radius","step":0.001,"type":"float"}],"shortdesc":"Simple runes"}},{"name":"runes_3","type":"shader","parameters":{"columns":1,"rows":4,"radius":0.025},"node_position":{"x":1595.15332,"y":139.420197},"seed_int":4028804864,"shader_model":{"code":"","global":"float ThickLine(vec2 uv, vec2 posA, vec2 posB)\n{\n\treturn sdLine(uv, posA, posB).x;\n}\n\n// makes a rune in the 0..1 uv space. Seed is which rune to draw.\n// passes back gray in x and derivates for lighting in yz\nfloat Rune(vec2 uv, float s) {\n\tfloat finalLine = 1.0;\n\tvec2 seed = floor(uv)-rand2(vec2(s));\n\tuv = fract(uv);\n\tfor (int i = 0; i < 4; i++)\t// number of strokes\n\t{\n\t\tvec2 posA = rand2(floor(seed+0.5));\n\t\tvec2 posB = rand2(floor(seed+1.5));\n\t\tseed += 2.0;\n\t\t// expand the range and mod it to get a nicely distributed random number - hopefully. :)\n\t\tposA = fract(posA * 128.0);\n\t\tposB = fract(posB * 128.0);\n\t\t// each rune touches the edge of its box on all 4 sides\n\t\tif (i == 0) posA.y = 0.0;\n\t\tif (i == 1) posA.x = 0.999;\n\t\tif (i == 2) posA.x = 0.0;\n\t\tif (i == 3) posA.y = 0.999;\n\t\t// snap the random line endpoints to a grid 2x3\n\t\tvec2 snaps = vec2(2.0, 3.0);\n\t\tposA = (floor(posA * snaps) + 0.5) / snaps;\t// + 0.5 to center it in a grid cell\n\t\tposB = (floor(posB * snaps) + 0.5) / snaps;\n\t\t//if (distance(posA, posB) < 0.0001) continue;\t// eliminate dots.\n\t\t// Dots (degenerate lines) are not cross-GPU safe without adding 0.001 - divide by 0 error.\n\t\tfinalLine = min(finalLine, ThickLine(uv, posA, posB + 0.001));\n\t}\n\treturn finalLine;\n}\n\n\n","includes":["sdline2"],"inputs":[],"instance":"","longdesc":"Generates a grid filled with random runes","name":"sdRunes","outputs":[{"longdesc":"A greyscale image showing random runes.","sdf2d":"Rune(vec2($columns, $rows)*$uv, float($seed))-$radius","shortdesc":"Output","type":"sdf2d"}],"parameters":[{"control":"None","default":0,"label":"Size X","longdesc":"The number of columns of the grid","max":32,"min":2,"name":"columns","shortdesc":"Size.x","step":1,"type":"float"},{"control":"None","default":0,"label":"Size Y","longdesc":"The number of rows of the grid","max":32,"min":2,"name":"rows","shortdesc":"Size.y","step":1,"type":"float"},{"control":"None","default":0.01,"label":"Radius","max":1,"min":0,"name":"radius","step":0.001,"type":"float"}],"shortdesc":"Simple runes"}},{"name":"transform2_7","type":"transform2","parameters":{"translate_x":-0.00605,"translate_y":0.17995,"rotate":0,"scale_x":0.55,"scale_y":0.55,"mode":0},"node_position":{"x":1840,"y":-440},"seed_int":0,"generic_size":1},{"name":"_3","type":"shader","parameters":{},"node_position":{"x":1800,"y":-760},"seed_int":0,"minimized":true,"shader_model":{"code":"float $(name_uv)_m = $bg($uv);\n\n#for\n$(name_uv)_m = max($(name_uv)_m,$in#($uv));\n#end","global":"","inputs":[{"default":"0.0","label":"","name":"bg","type":"f"},{"default":"0.0","label":"","name":"in#","type":"f"}],"instance":"","name":"Max","outputs":[{"f":"$(name_uv)_m","type":"f"}],"parameters":[]},"generic_size":3},{"name":"dilate","type":"dilate","parameters":{"param0":11,"param1":0.005,"param2":0,"param3":0,"param4":true},"node_position":{"x":2080,"y":-720},"seed_int":0},{"name":"gen_inputs","type":"ios","parameters":{},"node_position":{"x":-520,"y":-155.302521},"seed_int":0,"ports":[]},{"name":"gen_outputs","type":"ios","parameters":{},"node_position":{"x":2840,"y":-580},"seed_int":0,"ports":[{"name":"port0","type":"f"}]},{"name":"gen_parameters","type":"remote","parameters":{},"node_position":{"x":783.519653,"y":-1200},"seed_int":0,"widgets":[]},{"name":"transform2_8","type":"transform2","parameters":{"translate_x":-0.002,"translate_y":0,"rotate":0,"scale_x":1,"scale_y":1,"mode":0},"node_position":{"x":2480,"y":-600},"seed_int":0,"generic_size":1},{"name":"gradient_2","type":"gradient","parameters":{"repeat":1,"rotate":90,"gradient":{"type":"Gradient","points":[{"pos":0,"r":0,"g":0,"b":0,"a":1},{"pos":0.790698,"r":1,"g":1,"b":1,"a":1}],"interpolation":0}},"node_position":{"x":2138.025635,"y":-468.511566},"seed_int":0}],"connections":[{"from":"sdshow