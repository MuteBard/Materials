7453),cos($a*0.017453)))) * ($inv ? -1.0 : 1.0)","shortdesc":"Output","type":"sdf2d"}],"parameters":[{"control":"Radius1.a","default":0.5,"label":"Rad","max":360,"min":0,"name":"a","step":0.001,"type":"float"},{"control":"P1.x","default":0.5,"label":"X","max":1,"min":0,"name":"x","step":0.1,"type":"float"},{"control":"P1.y","default":0.5,"label":"Y","max":1,"min":0,"name":"y","step":0.1,"type":"float"},{"default":false,"label":"Invert","name":"inv","type":"boolean"}],"shortdesc":"sdBox"}},{"name":"sdannularshape_3","type":"sdannularshape","parameters":{"r":0.0166,"ripples":1},"node_position":{"x":1662.405029,"y":2374.598877},"seed_int":0},{"name":"sdbox","type":"sdbox","parameters":{"w":0.3,"h":0.1663,"cx":0,"cy":0},"node_position":{"x":2152.709717,"y":2389.71875},"seed_int":0},{"name":"sdboolean_6","type":"sdboolean","parameters":{"op":1},"node_position":{"x":2627.789551,"y":2413.599121},"seed_int":0},{"name":"sdboolean_8","type":"sdboolean","parameters":{"op":2},"node_position":{"x":2464.54541,"y":2563.119141},"seed_int":0},{"name":"sdboolean_9","type":"sdboolean","parameters":{"op":0},"node_position":{"x":2724.545166,"y":2521.118896},"seed_int":0},{"name":"sdannularshape_4","type":"sdannularshape","parameters":{"r":0.003,"ripples":1},"node_position":{"x":1883.405273,"y":2365.599121},"seed_int":0},{"name":"sdtranslate_5","type":"sdtranslate","parameters":{"x":0.1464,"y":0.0687},"node_position":{"x":2800.2854,"y":2283.679199},"seed_int":0},{"name":"sdboolean_10","type":"sdboolean","parameters":{"op":0},"node_position":{"x":3058.745605,"y":2365.519043},"seed_int":0},{"name":"sdboolean_7","type":"sdboolean","parameters":{"op":0},"node_position":{"x":3102.729492,"y":2235.318848},"seed_int":0},{"name":"shader_1","type":"shader","parameters":{"ax":0.118125,"ay":-0.0975,"bx":0.099375,"by":-0.01875,"cx":0.050625,"cy":0.045,"r":0.003},"node_position":{"x":2379.245361,"y":2641.518799},"seed_int":0,"shader_model":{"code":"","global":"float cro( in vec2 a, in vec2 b ) { return a.x*b.y - a.y*b.x; }\n\nfloat sdBezier( in vec2 pos, in vec2 A, in vec2 B, in vec2 C )\n{    \n    vec2 a = B - A;\n    vec2 b = A - 2.0*B + C;\n    vec2 c = a * 2.0;\n    vec2 d = A - pos;\n    float kk = 1.0/dot(b,b);\n    float kx = kk * dot(a,b);\n    float ky = kk * (2.0*dot(a,a)+dot(d,b)) / 3.0;\n    float kz = kk * dot(d,a);      \n    float res = 0.0;\n    float p = ky - kx*kx;\n    float p3 = p*p*p;\n    float q = kx*(2.0*kx*kx-3.0*ky) + kz;\n    float h = q*q + 4.0*p3;\n    if( h >= 0.0) \n    { \n        h = sqrt(h);\n        vec2 x = (vec2(h,-h)-q)/2.0;\n        vec2 uv = sign(x)*pow(abs(x), vec2(1.0/3.0));\n        float t = clamp( uv.x+uv.y-kx, 0.0, 1.0 );\n        res = dot2(d + (c + b*t)*t);\n    }\n    else\n    {\n        float z = sqrt(-p);\n        float v = acos( q/(p*z*2.0) ) / 3.0;\n        float m = cos(v);\n        float n = sin(v)*1.732050808;\n        vec3  t = clamp(vec3(m+m,-n-m,n-m)*z-kx,0.0,1.0);\n        res = min( dot2(d+(c+b*t.x)*t.x),\n                   dot2(d+(c+b*t.y)*t.y) );\n        // the third root cannot be the closest\n        // res = min(res,dot2(d+(c+b*t.z)*t.z));\n    }\n    return sqrt( res );\n}","inputs":[],"instance":"","name":"sdBezier","outputs":[{"sdf2d":"sdBezier($uv-.5,vec2($ax,$ay),vec2($bx,$by),vec2($cx,$cy))-$r","type":"sdf2d"}],"parameters":[{"control":"P1.x","default":0.5,"label":"AX","max":1,"min":0,"name":"ax","step":0.01,"type":"float"},{"control":"P1.y","default":0.5,"label":"AY","max":1,"min":0,"name":"ay","step":0.01,"type":"float"},{"control":"P3.x","default":0.5,"label":"BX","max":1,"min":0,"name":"bx","step":0.01,"type":"float"},{"control":"P3.y","default":0.5,"label":"BY","max":1,"min":0,"name":"by","step":0.01,"type":"float"},{"control":"P2.x","default":0.5,"label":"CX","max":1,"min":0,"name":"cx","step":0.01,"type":"float"},{"control":"P2.y","default":0.5,"label":"CY","max":1,"min":0,"name":"cy","step":0.01,"type":"float"},{"control":"None","default":0.5,"label":"Radius","max":1,"min":0,"name":"r","step":0.01,"type":"float"}]}},{"name":"sdboolean_11","type":"sdboolean","parameters":{"op":0},"node_position":{"x":2869.745605,"y":2635.519043},"seed_int":0},{"name":"shader_8","type":"shader","parameters":{"ax":0.121875,"ay":0.0075,"bx":0.110625,"by":0.12375,"cx":0.061875,"cy":0.2175,"r":0.003},"node_position":{"x":2198.245605,"y":2844.519043},"seed_int":0,"shader_model":{"code":"","global":"float cro( in vec2 a, in vec2 b ) { return a.x*b.y - a.y*b.x; }\n\nfloat sdBezier( in vec2 pos, in vec2 A, in vec2 B, in vec2 C )\n{    \n    vec2 a = B - A;\n    vec2 b = A - 2.0*B + C;\n    vec2 c = a * 2.0;\n    vec2 d = A - pos;\n    float kk = 1.0/dot(b,b);\n    float kx = kk * dot(a,b);\n    float ky = kk * (2.0*dot(a,a)+dot(d,b)) / 3.0;\n    float kz = kk * dot(d,a);      \n    float res = 0.0;\n    float p = ky - kx*kx;\n    float p3 = p*p*p;\n    float q = kx*(2.0*kx*kx-3.0*ky) + kz;\n    float h = q*q + 4.0*p3;\n    if( h >= 0.0) \n    { \n        h = sqrt(h);\n        vec2 x = (vec2(h,-h)-q)/2.0;\n        vec2 uv = sign(x)*pow(abs(x), vec2(1.0/3.0));\n        float t = clamp( uv.x+uv.y-kx, 0.0, 1.0 );\n        res = dot2(d + (c + b*t)*t);\n    }\n    else\n    {\n        float z = sqrt(-p);\n        float v = acos( q/(p*z*2.0) ) / 3.0;\n        float m = cos(v);\n        float n = sin(v)*1.732050808;\n        vec3  t = clamp(vec3(m+m,-n-m,n-m)*z-kx,0.0,1.0);\n        res = min( dot2(d+(c+b*t.x)*t.x),\n                   dot2(d+(c+b*t.y)*t.y) );\n        // the third root cannot be the closest\n        // res = min(res,dot2(d+(c+b*t.z)*t.z));\n    }\n    return sqrt( res );\n}","inputs":[],"instance":"","name":"sdBezier","outputs":[{"sdf2d":"sdBezier($uv-.5,vec2($ax,$ay),vec2($bx,$by),vec2($cx,$cy))-$r","type":"sdf2d"}],"parameters":[{"control":"P1.x","default":0.5,"label":"AX","max":1,"min":0,"name":"ax","step":0.01,"type":"float"},{"control":"P1.y","default":0.5,"label":"AY","max":1,"min":0,"name":"ay","step":0.01,"type":"float"},{"control":"P3.x","default":0.5,"label":"BX","max":1,"min":0,"name":"bx","step":0.01,"type":"float"},{"control":"P3.y","default":0.5,"label":"BY","max":1,"min":0,"name":"by","step":0.01,"type":"float"},{"control":"P2.x","default":0.5,"label":"CX","max":1,"min":0,"name":"cx","step":0.01,"type":"float"},{"control":"P2.y","default":0.5,"label":"CY","max":1,"min":0,"name":"cy","step":0.01,"type":"float"},{"control":"None","default":0.5,"label":"Radius","max":1,"min":0,"name":"r","step":0.01,"type":"float"}]}},{"name":"shader_9","type":"shader","parameters":{"ax":0.159375,"ay":0.20625,"bx":0.125625,"by":0.19875,"cx":0.136875,"cy":0.10875,"dx":0.563,"dy":0.539,"r":0.003},"node_position":{"x":2118.245605,"y":3023.518799},"seed_int":0,"shader_model":{"code":"","global":"/*\n * Cubic Bezier Spline Distance\n * \n * Copyright (C) 2021  Alexander Kraus <nr4@z10.info>\n * \n * This program is free software: you can redistribute it and/or modify\n * it under the terms of the GNU General Public License as published by\n * the Free Software Foundation, either version 3 of the License, or\n * (at your option) any later version.\n // Source: https://www.shadertoy.com/view/flsGzH \n * \n * This program is distributed in the hope that it will be useful,\n * but WITHOUT ANY WARRANTY; without even the implied warranty of\n * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n * GNU General Public License for more details.\n * \n * You should have received a copy of the GNU General Public License\n * along with this program.  If not, see <http://www.gnu.org/licenses/>.\n *\n * Update 1: Fixed a glitch related to the initial conditions of the\n *     interval approximation\n * Update 2: Used relative coordinates to simplify the equations\n * Update 3: Combined the dot products to save on computation time\n * \n */\n \nconst vec3 c = vec3(1.0,0.0,-1.0);\nconst float pi = 3.1415926;\n\n// Cubic bezier curve\nvec2 B3(float t, vec2 P0, vec2 P1, vec2 P2, vec2 P3)\n{\n    float m1 = 1.0-t;\n    return m1*m1*m1*P0 + 3.0*m1*t*(m1*P1+t*P2) + t*t*t*P3;\n}\n\n\n// Cubic bezier partial derivative with respect to t\nvec2 B3Prime(float t, vec2 P0, vec2 P1, vec2 P2, vec2 P3)\n{\n    float m1 = 1.0-t;\n    return 3.0*(m1*m1*(P1-P0)+2.0*m1*t*(P2-P1)+t*t*(P3-P2));\n}\n\n\n// Cubic bezier second partial derivative with respect to t\nvec2 B3Second(float t, vec2 P0, vec2 P1, vec2 P2, vec2 P3)\n{\n    float m1 = 1.0-t;\n    return 6.0*m1*(P2-2.0*P1+P0)+6.0*t*(P3-2.0*P2+P1);\n}\n\n// This is the \"easy\" representation of the quintic that has to be solved\n// for the sdf.\nfloat D3Prime(vec2 x, float  t, vec2 P0, vec2 P1, vec2 P2, vec2 P3)\n{\n    return dot(x-B3(t,P0,P1,P2,P3), B3Prime(t,P0,P1,P2,P3));\n}\n\n// Determine zeros of a*x^2+b*x+c\nvec2 quadratic_zeros(float a, float b, float cc) {\n    if(a == 0.0) return -cc/b*c.xx;\n    float d = b*b-4.0*a*cc;\n    if(d<0.0) return vec2(1.e4);\n    return (c.xz*sqrt(d)-b)/(2.0*a);\n}\n\n// Determine zeros of a*x^3+b*x^2+c*x+d\nvec3 cubic_zeros(float a, float b, float cc, float d) {\n    if(a == 0.0) return quadratic_zeros(b,cc,d).xyy;\n    \n    // Depress\n    vec3 ai = vec3(b,cc,d)/a;\n    \n    //discriminant and helpers\n    float tau = ai.x/3.0, \n        p = ai.y-tau*ai.x, \n        q = -tau*(tau*tau+p)+ai.z, \n        dis = q*q/4.0+p*p*p/27.0;\n        \n    //triple real root\n    if(dis > 0.0) {\n        vec2 ki = -0.5*q*c.xx+sqrt(dis)*c.xz, \n            ui = sign(ki)*pow(abs(ki), c.xx/3.0);\n        return vec3(ui.x+ui.y-tau);\n    }\n    \n    //three distinct real roots\n    float fac = sqrt(-4.0/3.0*p), \n        arg = acos(-0.5*q*sqrt(-27.0/p/p/p))/3.0;\n    return c.zxz*fac*cos(arg*c.xxx+c*pi/3.0)-tau;\n}\n\n// Determine zeros of a*x^4+b*x^3+c*x^2+d*x+e\nvec4 quartic_zeros(float a, float b, float cc, float d, float e) {\n    if(a == 0.0) return cubic_zeros(b, cc, d, e).xyzz;\n    \n    // Depress\n    float _b = b/a,\n        _c = cc/a,\n        _d = d/a,\n        _e = e/a;\n        \n    // Helpers\n    float p = (8.0*_c-3.0*_b*_b)/8.0,\n        q = (_b*_b*_b-4.0*_b*_c+8.0*_d)/8.0,\n        r = (-3.0*_b*_b*_b*_b+256.0*_e-64.0*_b*_d+16.0*_b*_b*_c)/256.0;\n        \n    // Determine available resolvent zeros\n    vec3 res = cubic_zeros(8.0,8.0*p,2.0*p*p-8.0*r,-q*q);\n    \n    // Find nonzero resolvent zero\n    float m = res.x;\n    if(m == 0.0) m = res.y;\n    if(m == 0.0) m = res.z;\n    \n    // Apply Ferrari method\n    return vec4(\n        quadratic_zeros(1.0,sqrt(2.0*m),p/2.0+m-q/(2.0*sqrt(2.0*m))),\n        quadratic_zeros(1.0,-sqrt(2.0*m),p/2.0+m+q/(2.0*sqrt(2.0*m)))\n    )-_b/4.0;\n}\n\n// minimum distance to a cubic spline with the following strategy:\nfloat dcubic_spline(in vec2 x, in vec2 p0, in vec2 p1, in vec2 p2, in vec2 p3)\n{\n    // Use relative coordinates to eliminate all terms containing p0.\n    x -= p0;\n    p1 -= p0;\n    p2 -= p0;\n    p3 -= p0;\n    p0 = c.yy;\n \n    // Use interval approximation to determine a numerical solution for the quintic.\n    // TODO: find something better, I really would like an analytical approach\n    float tmin = -0.5, tmax = 1.5, tnew, \n        dmin = D3Prime(x,tmin,p0,p1,p2,p3),\n        dmax = D3Prime(x,tmax,p0,p1,p2,p3),\n        dnew;\n    \n    for(int i=0; i<20; ++i)\n    {\n        tnew = mix(tmin, tmax, .5);\n        dnew = D3Prime(x,tnew,p0,p1,p2,p3);\n        \n        if(dnew>0.0)\n        {\n            tmin = tnew;\n            dmin = dnew;\n        }\n        else \n        {\n            tmax = tnew;\n            dmax = dnew;\n        }\n    }\n    \n    // Determine coefficients of quintic equation.\n    vec2 pa = p2-p1;\n    float a5 = -dot(p3,p3)+3.0*dot(pa,2.0*p3-3.0*pa),\n        a4 = 5.0*dot(p1-pa,p3)+15.0*dot(pa,pa-p1),\n        a3 = -6.0*dot(p2,p2)+4.0*dot(p1,9.0*pa-p3),\n        a2 = dot(p3-3.0*pa,x)+9.0*dot(p1,p1-pa),\n        a1 = 2.0*dot(pa-p1,x)-3.0*dot(p1,p1),\n        a0 = dot(p1,x);\n    \n    // Polynomial division of numerical solution.\n    float _a = a5,\n        _b = a4+_a*tmin,\n        _c = a3+_b*tmin,\n        _d = a2+_c*tmin,\n        _e = a1+_d*tmin;\n        \n    vec4 t = clamp(quartic_zeros(_a,_b,_c,_d,_e),0.0,1.0);\n    tmin = clamp(tmin, 0.0,1.0);\n    \n    return min(\n        length(x-B3(tmin,p0,p1,p2,p3)),\n        min(\n            min(\n                length(x-B3(t.x,p0,p1,p2,p3)),\n                length(x-B3(t.y,p0,p1,p2,p3))\n            ),\n            min(\n                length(x-B3(t.z,p0,p1,p2,p3)),\n                length(x-B3(t.w,p0,p1,p2,p3))\n            )\n        )\n    );\n}","inputs":[],"instance":"","name":"sdCubicBezier","outputs":[{"sdf2d":"dcubic_spline($uv,vec2($ax,$ay)+0.5, vec2($bx,$by)+0.5, vec2($cx, $cy)+0.5, vec2($dx,$dy))-$r","shortdesc":"Output","type":"sdf2d"}],"parameters":[{"control":"P1.x","default":0.5,"label":"A","max":1,"min":0,"name":"ax","step":0.1,"type":"float"},{"control":"P1.y","default":0.5,"label":"1:","max":1,"min":0,"name":"ay","step":0.1,"type":"float"},{"control":"P3.x","default":0.5,"label":"B","max":1,"min":0,"name":"bx","step":0.1,"type":"float"},{"control":"P3.y","default":0.5,"label":"2:","max":1,"min":0,"name":"by","step":0.1,"type":"float"},{"control":"P2.x","default":0.5,"label":"C","max":1,"min":0,"name":"cx","step":0.1,"type":"float"},{"control":"P2.y","default":0.5,"label":"3:","max":1,"min":0,"name":"cy","step":0.1,"type":"float"},{"control":"None","default":0.5,"label":"D","max":1,"min":0,"name":"dx","step":0.1,"type":"float"},{"control":"None","default":0.5,"label":"4:","max":1,"min":0,"name":"dy","step":0.1,"type":"float"},{"control":"None","default":0.5,"label":"Radius","max":1,"min":0,"name":"r","step":0.1,"type":"float"}]}},{"name":"sdboolean_12","type":"sdboolean","parameters":{"op":0},"node_position":{"x":2730.745605,"y":2732.519043},"seed_int":0},{"name":"transform2_4","type":"transform2","parameters":{"translate_x":0,"translate_y":0,"rotate":0,"scale_x":0.15875,"scale_y":0.955,"mode":0},"node_position":{"x":2683.748779,"y":3132.76001},"seed_int":0,"generic_size":1},