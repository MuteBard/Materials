 c * c;\n        }\n    }\n\n    for (int j = 0; j <= int(radius); ++j)  {\n        for (int i = -int(radius); i <= 0; ++i)  {\n            vec3 c = $in( uv + vec2( float(i), float(j)) * offset / 100.0);\n            m[3] += c;\n            s[3] += c * c;\n        }\n    }\n\t\n    float min_sigma2 = 1e+2;\n    for (int k = 0; k < 4; ++k) {\n        m[k] /= n;\n        s[k] = abs(s[k] / n - m[k] * m[k]);\n\n        float sigma2 = s[k].r + s[k].g + s[k].b;\n        if (sigma2 < min_sigma2) {\n            min_sigma2 = sigma2;\n            color = vec3(m[k]);\n        }\n    }\n\treturn color;\n}","name":"Kuwahara Filter","outputs":[{"rgb":"$(name)_kuwahara($uv, $radius, $offset)","type":"rgb"}],"parameters":[{"control":"None","default":4.0,"label":"Iterations","max":10.0,"min":1.0,"name":"radius","step":1.0,"type":"float"},{"control":"None","default":0.01,"label":"Offset","max":1.0,"min":0.0,"name":"offset","step":0.01,"type":"float"}]},"type":"shader"},{"name":"fbm2","node_position":{"x":2040.0,"y":-1220.0},"parameters":{"folds":0.0,"iterations":4.0,"noise":1.0,"offset":0.0,"persistence":0.5,"scale_x":10.0,"scale_y":10.0},"seed_int":0,"type":"fbm2"},{"generic_size":1,"name":"blend2_10","node_position":{"x":2500.0,"y":-1280.0},"parameters":{"amount1":1.0,"blend_type1":0.0},"seed_int":0,"type":"blend2"},{"name":"tones_step_2","node_position":{"x":-940.0,"y":-2020.0},"parameters":{"invert":false,"value":0.59,"width":0.16},"seed_int":0,"type":"tones_step"},{"name":"385","node_position":{"x":0.0,"y":-1880.0},"parameters":{"offset":0.04,"radius":6.0},"seed":-14799.0,"shader_model":{"code":"","global":"","inputs":[{"default":"vec3(1.0)","function":true,"label":"","name":"in","type":"rgb"}],"instance":"vec3 $(name)_kuwahara(vec2 uv, float radius, float offset) {\n\tfloat n = (radius + 1.0) * (radius + 1.0);\n\tvec3 color = vec3(0.0);\n\t\n    vec3 m[4];\n    vec3 s[4];\n    for (int k = 0; k < 4; ++k) {\n        m[k] = vec3(0.0);\n        s[k] = vec3(0.0);\n    }\n\n    for 