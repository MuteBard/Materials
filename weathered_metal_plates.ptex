ize","step":0.01,"type":"named_parameter"},{"default":0.0,"label":"Spacing","max":1.0,"min":0.0,"name":"spacing","step":0.01,"type":"named_parameter"},{"label":"Spacing Rand","linked_widgets":[{"node":"_3","widget":"rnd"}],"name":"param1","type":"linked_control"},{"label":"Pos Rand","linked_widgets":[{"node":"_4","widget":"rnd"}],"name":"param0","type":"linked_control"}]},{"name":"shader_1","node_position":{"x":60.0,"y":1396.0},"parameters":{},"seed_int":0,"shader_model":{"code":"","global":"","inputs":[{"default":"vec4(1.0)","label":"","name":"in","type":"fill"}],"instance":"","name":"Fill to RGBA","outputs":[{"rgba":"$in($uv)","type":"rgba"}],"parameters":[]},"type":"shader"},{"name":"math_16","node_position":{"x":-620.0,"y":2960.0},"parameters":{"clamp":false,"default_in1":0.0,"default_in2":0.0,"op":3.0},"seed_int":0,"type":"math"},{"name":"math_15","node_position":{"x":-620.0,"y":2800.0},"parameters":{"clamp":false,"default_in1":0.0,"default_in2":0.0,"op":12.0},"seed_int":0,"type":"math"},{"name":"math_17","node_position":{"x":-620.0,"y":2640.0},"parameters":{"clamp":false,"default_in1":"$uv.y","default_in2":0.0,"op":1.0},"seed_int":0,"type":"math"},{"name":"math_8","node_position":{"x":-40.0,"y":2640.0},"parameters":{"clamp":false,"default_in1":0.0,"default_in2":"$size","op":2.0},"seed_int":0,"type":"math"},{"name":"math_9","node_position":{"x":-40.0,"y":2940.0},"parameters":{"clamp":false,"default_in1":0.0,"default_in2":"$size","op":2.0},"seed_int":0,"type":"math"},{"name":"math_11","node_position":{"x":-280.0,"y":2680.0},"parameters":{"clamp":false,"default_in1":"$size","default_in2":0.0,"op":15.0},"seed_int":0,"type":"math"},{"name":"math_18","node_position":{"x":-260.0,"y":2920.0},"parameters":{"clamp":false,"default_in1":"1.0 - $size","default_in2":0.0,"op":15.0},"seed_int":0,"type":"math"},{"name":"_2","node_position":{"x":22.0,"y":1165.0},"parameters":{"size":"$d_size / 10.0"},"seed_int":0,"shader_model":{"code":"","global":"","inputs":[{"default":"vec4(0.0, 0.0, 1.0, 1.0)","function":true,"label":"","name":"in","type":"fill"}],"instance":"vec4 pattern_$(name)(vec2 uv, float size) {\n\tvec4 bb = $in(uv);\n\t\n\tvec2 m_size = min(vec2(size), bb.zw / 2.0);\n\t\n\t\n\tvec2 new_zw = bb.zw;\n\t\n\tif (uv.x - bb.x > bb.z - m_size.x ) {\n\t\tbb.x += bb.z - m_size.x; // the far right part\n\t\tnew_zw.x = m_size.x;\n\t} else if(uv.x - bb.x > m_size.x){\n\t\tbb.x += m_size.x; // the center part\n\t\tnew_zw.x -= 2.0 * m_size.x;\n\t} else {\n\t\tnew_zw.x = m_size.x; // the left part\n\t}\n\t\n\tif (uv.y - bb.y > bb.w - m_size.y ) {\n\t\tbb.y += bb.w - m_size.y; // the far right part\n\t\tnew_zw.y = m_size.y;\n\t} else if(uv.y - bb.y > m_size.y){\n\t\tbb.y += m_size.y; // the center part\n\t\tnew_zw.y -= 2.0 * m_size.y;\n\t} else {\n\t\tnew_zw.y = m_size.y;\n\t}\t\n\t\n\tbb.zw = new_zw;\n\treturn bb;\n}","name":"Edge Fills","outputs":[{"fill":"pattern_$(name)($uv, $size)","type":"fill"}],"parameters":[{"control":"None","default":0.1,"label":"Size","max":1.0,"min":0.0,"name":"size","step":0.01,"type":"float"}]},"type":"shader"},{"name":"shader_3","node_position":{"x":63.0,"y":1476.0},"parameters":{},"seed_int":0,"shader_model":{"code":"","global":"","inputs":[{"default":"vec4(1.0)","label":"","name":"in","type":"rgba"}],"instance":"","name":"RGBA to Fill","outputs":[{"fill":"$in($uv)","type":"fill"}],"parameters":[]},"type":"shader"},{"name":"fill_to_uv","node_position":{"x":1053.0,"y":1027.0},"parameters":{"mode":0.0},"seed_int":0,"type":"fill_to_uv2"},{"name":"custom_uv","node_position":{"x":1541.0,"y":761.0},"parameters":{"inputs":0.0,"rotate":180.0,"scale":0.0,"sx":1.0,"sy":1.0,"variations":false},"seed_int":0,"type":"custom_uv"},{"name":"shape","node_position":{"x":1284.0,"y":634.0},"parameters":{"edge":1.0,"radius":0.85,"shape":1.0,"sides":6.0},"seed_int":0,"type":"shape"},{"name":"_3","node_position":{"x":266.2900390625,"y":1150.0},"parameters":{"rnd":0.09,"size":"$d_size / 10.0 + $spacing"},"seed_int":1627467264,"shader_model":{"code":"","global":"","inputs":[{"default":"vec4(0.0, 0.0, 1.0, 1.0)","function":true,"label":"","name":"in","type":"fill"}],"instance":"vec4 pattern_$(name)(vec2 uv, float size, float seed, float rnd) {\n\tvec4 bb = $in(uv);\n\t\n\tif (max(bb.z, bb.w) < size * 2.0) {\n\t\treturn bb;\n\t}\n\t\n\tvec4 new_bb = bb;\n\t\n\tfloat random_value = rand(vec2(seed)+bb.xy+bb.zw);\n\trandom_value = mix(1.0, random_value, rnd);\n\t\n\tif (bb.z > bb.w) {\n\t\tfloat ammount = bb.z / size;\n\t\tammount = mix(1.0, ammount, random_value);\n\t\tammount = floor(ammount);\n\t\tfloat n_size = bb.z / ammount;\n\t\tnew_bb.x += (floor(((uv.x - bb.x) / bb.z) * ammount) / ammount) * bb.z;\n\t\tnew_bb.z = n_size;\n\t} else {\n\t\tfloat ammount = bb.w / size;\n\t\tammount = mix(1.0, ammount, random_value);\n\t\tammount = floor(ammount);\n\t\tfloat n_size = bb.w / ammount;\n\t\tnew_bb.y += (floor(((uv.y - bb.y) / bb.w) * ammount) / ammount) * bb.w;\n\t\tnew_bb.w = n_size;\n\t}\n\t\n\treturn new_bb;\n}","name":"Cut Fills","outputs":[{"fill":"pattern_$(name)($uv, $size, $seed, $rnd)","type":"fill"}],"parameters":[{"control":"None","default":0.1,"label":"Size","max":1.0,"min":0.0,"name":"size","step":0.01,"type":"float"},{"control":"None","default":0.0,"label":"Randomness","max":1.0,"min":0.0,"name":"rnd","step":0.01,"type":"float"}]},"type":"shader"},{"name":"fill_to_uv_3","node_position":{"x":1030.2900390625,"y":461.0},"parameters":{"mode":0.0},"seed_int":0,"shader_model":{"code":"vec4 $(name_uv)_bb = $in($uv);","global":"vec3 fill_to_uv_stretch(vec2 coord, vec4 bb, float seed) {\n\tvec2 uv_islands = fract(coord-bb.xy)/bb.zw;\n\tfloat random_value = rand(vec2(seed)+bb.xy+bb.zw);\n\treturn vec3(uv_islands, random_value);\n}\n\nvec3 fill_to_uv_square(vec2 coord, vec4 bb, float seed) {\n\tvec2 uv_islands;\n\tif (bb.z > bb.w) {\n\t\tvec2 adjusted_coord = coord + vec2(0.0, (bb.z - bb.w) / 2.0);\n\t\tuv_islands = fract(adjusted_coord-bb.xy)/bb.zz;\n\t} else {\n\t\tvec2 adjusted_coord = coord + vec2((bb.w - bb.z) / 2.0, 0.0);\n\t\tuv_islands = fract(adjusted_coord-bb.xy)/bb.ww;\n\t}\n\tfloat random_value = rand(vec2(seed)+bb.xy+bb.zw);\n\treturn vec3(uv_islands, random_value);\n}","inputs":[{"default":"vec4(0.0)","label":"","longdesc":"The input fill data, to be connected to the output of a Fill node","name":"in","shortdesc":"Input","type":"fill"}],"instance":"","longdesc":"A fill companion node that generated an UV map that follows each filled area","name":"Fill to UV      ","outputs":[{"longdesc":"The generated output UV map, to be connected to a Custom UV node","rgb":"fill_to_uv_$mode($uv, $(name_uv)_bb, float($seed))","shortdesc":"Output","type":"rgb"}],"parameters":[{"default":0.0,"label":"","longdesc":"The mode decides how the UVs are layed out on each bounding box:\n- Stretch mode where the UV layout is stretched to the bounding box. \n- Square mode where the UV layout is even and centerered based on the longest axis of the bounding box.","name":"mode","shortdesc":"Mode","type":"enum","values":[{"name":"Stretch","value":"stretch"},{"name":"Square","value":"square"}]}],"shortdesc":"Fill to UV"},"type":"shader"},{"name":"_4","node_position":{"x":564.494140625,"y":1147.0},"parameters":{"rnd":0.46},"seed_int":0,"shader_model":{"code":"","global":"","inputs":[{"default":"vec4(0.0, 0.0, 1.0, 1.0)","function":true,"label":"","name":"in","type":"fill"}],"instance":"vec4 pattern_$(name)(vec2 uv, float rnd, float seed) {\n\tvec4 bb = $in(uv);\n\t\n\tfloat random_value = rand(vec2(seed)+bb.xy+bb.zw);\n\trandom_value = mix(0.5, random_value, rnd);\n\t\n\tvec2 centre = bb.xy + bb.zw / 2.0;\n\t\n\tfloat s = min(bb.z, bb.w);\n\t\n\tif (bb.z > bb.w) {\n\t\tcentre.x = mix(bb.x + s / 2.0, bb.x + bb.z - s / 2.0, random_value); \n\t} else {\n\t\tcentre.y = mix(bb.y + s / 2.0, bb.y + bb.w - s / 2.0, random_value);\n\t}\n\t\n\tbb.z = s;\n\tbb.w = s;\n\t\n\tbb.x = centre.x - bb.z / 2.0;\n\tbb.y = centre.y - bb.w / 2.0;\n\t\n\treturn bb;\n}","name":"Make Fills Square","ou