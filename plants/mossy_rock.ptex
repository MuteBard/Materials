ode":0},"node_position":{"x":-554.725464,"y":-34.178955},"seed":-47470,"seed_locked":true,"shader_model":{"code":"","global":"","inputs":[{"default":"vec4(1.0)","function":true,"label":"","name":"in","type":"rgba"},{"default":"1.0","function":true,"label":"","name":"heightmap","type":"f"}],"instance":"vec4 $(name)_fct(vec2 uv) {\n\tfloat dx = 1.0/$size;\n    float v = $heightmap(uv);\n\tvec2 slope = vec2($heightmap(uv+vec2(dx, 0.0))-v, $heightmap(uv+vec2(0.0, dx))-v);\n\tfloat slope_strength = length(slope)*$size;\n    vec2 norm_slope =  (slope_strength == 0.0) ? vec2(0.0, 1.0) : normalize(slope);\n\tfloat mapped_quality = 1.0 + ($quality - 1.0) * ($size - 1.0) / (100.0 - 1.0);\n\tvec4 rv = vec4(0.0);\n\tfloat sum = 0.0;\n\tfloat sigma = max($sigma*slope_strength, 0.0001);\n\tfloat step_size = max(dx,1.0/mapped_quality);\n\t//maxium number of loop iterations = 1024\n\tstep_size = max($mode/1024.0,step_size);\n\tstep_size -= mod(step_size, dx);\n\tfor (float i = 0.0; i <= $mode; i += step_size) {\n\t\tfloat coef = exp(-0.5*(pow(i/sigma, 2.0)))/(6.28318530718*sigma*sigma);\n\t\trv += $in(uv+i*norm_slope*$sigma*3.0)*coef;\n\t\tsum += coef;\n\t}\n\treturn rv/sum;\n}","name":"Slope Blur HQ","outputs":[{"rgba":"$(name)_fct($uv)","type":"rgba"}],"parameters":[{"default":9,"first":4,"label":"Size","last":12,"name":"size","type":"size"},{"control":"None","default":0.5,"label":"Sigma","max":1,"min":0,"name":"sigma","step":0.001,"type":"float"},{"control":"None","default":50,"label":"Quality","max":100,"min":0,"name":"quality","step":1,"type":"float"},{"control":"None","default":50,"label":"Range","max":1,"min":0,"name":"range","step":0.001,"type":"float"},{"default":0,"label":"Mode","name":"mode","type":"enum","values":[{"name":"Range","value":"$range"},{"name":"Soft","value":"$sigma*3.0"}]}]}},{"name":"buffer_2","type":"buffer","parameters":{"size":11,"lod":0},"node_position":{"x":-309.952209,"y":-63.576294},"seed":36948,"seed_locked":false}],"connections":[{"from":"gen_inpu