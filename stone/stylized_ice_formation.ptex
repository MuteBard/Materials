":0.0,"y":0.0},"nodes":[{"export":{},"export_last_target":"Godot/Godot 4","export_paths":{},"name":"Material","node_position":{"x":-2029.69934082031,"y":4684.0234375},"parameters":{"albedo_color":{"a":1.0,"b":1.0,"g":1.0,"r":1.0,"type":"Color"},"ao":0.0,"depth_scale":0.51,"emission_energy":0.0,"flags_transparent":true,"iter":24.0,"metallic":0.0,"normal":0.66,"offset_scale":0.04,"roughness":1.0,"size":11.0},"seed_int":0,"shader_model":{"code":"","exports":{"Godot/Godot 4":{"export_extension":"tres","files":[{"file_name":"$(path_prefix).gdshader","prompt_overwrite":false,"template":"shader_type spatial;\nrender_mode blend_mix,cull_back,diffuse_burley,specular_schlick_ggx\n$if $(connected:opacity_tex) and $(param:flags_transparent)\n,depth_prepass_alpha\n$fi\n;\nuniform sampler2D texture_albedo; // $output(0)\nuniform sampler2D texture_emission : hint_default_black; // $output(2)\nuniform sampler2D texture_normal : hint_normal; // $output(3)\nuniform sampler2D texture_orm : hint_default_white; // $output(1)\nuniform sampler2D texture_parallax; // $output(5)\nuniform vec3 uv1_scale;\nuniform vec3 uv1_offset;\n$definitions float_uniform_to_const, rename_buffers\nvoid vertex() {\n\tUV=UV*uv1_scale.xy+uv1_offset.xy;\n}\nvoid fragment() {\n\tvec2 base_uv = UV;\n\tint texture_size = textureSize(texture_albedo, 0).x;\n\tif (texture_size < 256) {\n\t\tbase_uv = floor(float(texture_size)*base_uv+0.5)/float(texture_size);\n\t}\n\tvec3 parallax = vec3(0.0);\n$if $(connected:parallax_tex)\n\t{\n$begin_generate\n\t\tint p_iter = int($iter);\n$end_generate\n\t\tvec3 view_dir = inverse(mat3(TANGENT, -BINORMAL, NORMAL))*VIEW;\n\t\tfor (int j = 0; j < p_iter; j++) {\n\t\t\tfloat ratio = float(j) / float(p_iter);\n$begin_generate\n\t\t\tparallax += texture(texture_parallax, base_uv - mix(0.0, $offset_scale, ratio) * view_dir.xy).rgb * mix(1.0, 0.0, ratio);\n$end_generate\n\t\t}\n\t\tparallax /= float(p_iter);\n\t}\n$fi\n$begin_generate rename_buffers\n\tvec4 albedo_tex = texture(texture_albedo, base_uv);\n\tALBEDO = $albedo_color.rgb * mix(pow((albedo_tex + vec4(0.055))/vec4(1.055), vec4(2.4)), albedo_tex/vec4(12.92), lessThan(albedo_tex, vec4(0.04045))).rgb;\n\tALBEDO += parallax;\n\tvec4 orm_tex = texture(texture_orm, base_uv);\n\tMETALLIC = $metallic*orm_tex.b;\n\tROUGHNESS = $roughness*orm_tex.g;\n\tSPECULAR = 0.5;\n\tNORMAL_MAP = texture(texture_normal, base_uv).rgb;\n\tNORMAL_MAP_DEPTH = $normal;\n\tvec3 emission_tex = texture(texture_emission, base_uv).rgb;\n\tEMISSION = emission_tex*$emission_energy;\n\tAO = orm_tex.r;\n\tAO_LIGHT_AFFECT = $ao;\n$if $(connected:opacity_tex) and $(param:flags_transparent)\n\tALPHA = albedo_tex.a;\n\tALPHA_SCISSOR_THRESHOLD = 0.01;\n$fi\n$end_generate\n}\n","type":"template"},{"file_name":"$(path_prefix).tres","prompt_overwrite":false,"template":"[gd_resource type=\"ShaderMaterial\" load_steps=6 format=2]\n[ext_resource path=\"$(file_prefix).gdshader\" type=\"Shader\" id=1]\n$if $(connected:albedo_tex)\n[ext_resource path=\"$(file_prefix)_albedo.png\" type=\"Texture\" id=2]\n$fi\n$if $(connected:normal_tex)\n[ext_resource path=\"$(file_prefix)_normal.png\" type=\"Texture\" id=3]\n$fi\n$if $(connected:ao_tex) or $(connected:roughness_tex) or $(connected:metallic_tex)\n[ext_resource path=\"$(file_prefix)_orm.png\" type=\"Texture\" id=4]\n$fi\n$if $(connected:parallax_tex)\n[ext_resource path=\"$(file_prefix)_parallax.png\" type=\"Texture\" id=5]\n$fi\n$if $(connected:emission_tex)\n[ext_resource path=\"$(file_prefix)_emissoin.png\" type=\"Texture\" id=6]\n$fi\n[resource]\nshader = ExtResource( 1 )\n$if $(connected:albedo_tex)\nshader_parameter/texture_albedo = ExtResource( 2 )\n$fi\n$if $(connected:normal_tex)\nshader_parameter/texture_normal = ExtResource( 3 )\n$fi\n$if $(connected:ao_tex) or $(connected:roughness_tex) or $(connected:metallic_tex)\nshader_parameter/texture_orm = ExtResource( 4 )\n$fi\n$if $(connected:parallax_tex)\nshader_parameter/texture_parallax = ExtResource( 5 )\n$fi\n$if $(connected:emission_tex)\nshader_parameter/texture_emission = ExtResource( 6 )\n$fi\n$if $(connected:emission_tex)\nemission_enabled = true\nemission = Color( 0, 0, 0, 1 )\nemission_energy = $(param:emission_energy)\nemission_operator = 0\nemission_texture = ExtResource( 5 )\n$fi\n$if $(connected:normal_tex)\nnormal_enabled = true\n$fi\nshader_parameter/uv1_scale = Vector3(1, 1, 0)\n","type":"template"},{"conditions":"$(connected:albedo_tex)","file_name":"$(path_prefix)_albedo.png","output":0.0,"prompt_overwrite":false,"type":"texture"},{"conditions":"$(connected:normal_tex)","file_name":"$(path_prefix)_normal.png","output":3.0,"prompt_overwrite":false,"type":"texture"},{"conditions":"$(connected:ao_tex) or $(connected:roughness_tex) or $(connected:metallic_tex)","file_name":"$(path_prefix)_orm.png","output":1.0,"prompt_overwrite":false,"type":"texture"},{"conditions":"$(connected:parallax_tex)","file_name":"$(path_prefix)_parallax.png","output":5.0,"prompt_overwrite":false,"type":"texture"},{"conditions":"$(connected:emission_tex)","file_name":"$(path_prefix)_emission.png","output":2.0,"prompt_overwrite":false,"type":"texture"}]}},"global":"","inputs":[{"default":"vec3(1.0)","label":"","name":"albedo_tex","type":"rgb"},{"default":"1.0","label":"","name":"metallic_tex","type":"f"},{"default":"1.0","label":"","name":"roughness_tex","type":"f"},{"default":"vec3(0.0)","label":"","name":"emission_tex","type":"rgb"},{"default":"vec3(0.5)","label":"","name":"normal_tex","type":"rgb"},{"default":"1.0","label":"","name":"ao_tex","type":"f"},{"default":"vec3(1.0)","label":"","name":"parallax_tex","type":"rgb"},{"default":"1.0","label":"","name":"opacity_tex","type":"f"},{"default":"0.0","label":"11:","name":"depth_tex","type":"f"}],"instance":"","longdesc":"PBR material with maps generated as static images","name":"Static PBR Material Parallax","outputs":[{"rgba":"vec4($albedo_tex($uv), $opacity_tex($uv))","type":"rgba"},{"rgb":"vec3($ao_tex($uv), $roughness_tex($uv), $metallic_tex($uv))","type":"rgb"},{"rgb":"$emission_tex($uv)","type":"rgb"},{"rgb":"$normal_tex($uv)*vec3(-1.0, 1.0, -1.0)+vec3(1.0, 0.0, 1.0)","type":"rgb"},{"f":"$depth_tex($uv)","type":"f"},{"rgb":"$parallax_tex($uv)","type":"rgb"},{"rgba":"vec4(vec3($metallic_tex($uv)), 1.0-$roughness_tex($uv))","type":"rgba"},{"rgb":"$normal_tex($uv)*vec3(-1.0, 1.0, -1.0)+vec3(1.0, 0.0, 1.0)","type":"rgb"},{"f":"1.0-$depth_tex($uv)","type":"f"},{"f":"$ao_tex($uv)","type":"f"},{"rgb":"$normal_tex($uv)*vec3(-1.0)+vec3(1.0)","type":"rgb"},{"rgba":"vec4($metallic_tex($uv), $ao_tex($uv), 1.0, 1.0-$roughness_tex($uv))","type":"rgba"},{"f":"$metallic_tex($uv)","type":"f"},{"f":"$roughness_tex($uv)","type":"f"}],"parameters":[{"default":{"a":1.0,"b":1.0,"g":1.0,"r":1.0},"label":"Albedo","name":"albedo_color","type":"color"},{"control":"None","default":1.0,"label":"Metallic","max":1.0,"min":0.0,"name":"metallic","step":0.01,"type":"float"},{"control":"None","default":1.0,"label":"Roughness","max":1.0,"min":0.0,"name":"roughness","step":0.01,"type":"float"},{"control":"None","default":1.0,"label":"Emission","max":1.0,"min":0.0,"name":"emission_energy","step":0.01,"type":"float"},{"control":"None","default":1.0,"label":"Normal","max":10.0,"min":0.0,"name":"normal","step":0.01,"type":"float"},{"control":"None","default":1.0,"label":"Ambient occlusion","max":1.0,"min":0.0,"name":"ao","step":0.01,"type":"float"},{"control":"None","default":0.5,"label":"Parallax","max":1.0,"min":0.0,"name":"offset_scale","step":0.01,"type":"float"},{"default":false,"label":"Transparency","name":"flags_transparent","type":"boolean"},{"default":11.0,"first":6.0,"label":"Textures Size","last":13.0,"name":"size","type":"size"},{"control":"None","default":16.0,"label":"Parallax Steps","max":64.0,"min":2.0,"name":"iter","step":1.0,"type":"float"},{"control":"None","default":0.5,"label":"Depth","max":1.0,"min":0.0,"name":"depth_scale","step":0.01,"type":"float"}],"preview_shader":"shader_type spatial;\nrender_mode blend_mix,cull_back,diffuse_burley,specular_schlick_ggx\n$if $(connected:opacity_tex) and $(param:flags_transparent)\n,depth_prepass_alpha\n$fi\n;\n\nuniform sampler2D texture_albedo : source_color; // $output(0)\nuniform sampler2D texture_emission : hint_default_black; // $output(2)\nuniform sampler2D texture_normal : hint_normal; // $output(3)\nuniform sampler2D texture_orm : hint_default_white; // $output(1)\nuniform sampler2D texture_parallax : source_color; // $output(5)\nuniform sampler2D texture_depth : hint_default_black; // $output(4)\nuniform int depth_min_layers = 8;\nuniform int depth_max_layers = 32;\nuniform vec2 depth_flip = vec2(1.0);\nuniform float depth_offset = 0.0;\n\nuniform vec3 uv1_scale;\nuniform vec3 uv1_offset;\n\n$definitions\n\nvoid vertex() {\n\tUV=UV*uv1_scale.xy+uv1_offset.xy;\n$if $(connected:depth_tex)\n$begin_generate\n\t\tfloat depth_scale = 0.2*$depth_scale;\n$end_generate\n\t\tVERTEX += NORMAL * (1.0 - depth_offset - texture(texture_depth, UV).r) * depth_scale; \n$fi\n}\n\nvoid fragment() {\n\tvec2 base_uv = UV;\n\tint texture_size = textureSize(texture_albedo, 0).x;\n\tif (texture_size < 256) {\n\t\tbase_uv = floor(float(texture_size)*base_uv+0.5)/float(texture_size);\n\t}\n\tvec3 parallax = vec3(0.0);\n$if $(connected:parallax_tex)\n\t{\n$begin_generate\n\t\tint p_iter = int($iter);\n$end_generate\n\t\tvec3 view_dir = inverse(mat3(TANGENT, -BINORMAL, NORMAL))*VIEW;\n\t\tfor (int j = 0; j < p_iter; j++) {\n\t\t\tfloat ratio = float(j) / float(p_iter);\n$begin_generate\n\t\t\tparallax += texture(texture_parallax, base_uv - mix(0.0, $offset_scale, ratio) * view_dir.xy).rgb * mix(1.0, 0.0, ratio);\n$end_generate\n\t\t}\n\t\tparallax /= float(p_iter);\n\t}\n$fi\n$begin_generate\n\tvec4 albedo_tex = texture(texture_albedo, base_uv);\n\tALBEDO = $albedo_color.rgb * mix(pow((albedo_tex + vec4(0.055))/vec4(1.055), vec4(2.4)), albedo_tex/vec4(12.92), lessThan(albedo_tex, vec4(0.04045))).rgb;\n\tALBEDO += parallax;\n\tvec4 orm_tex = texture(texture_orm, base_uv);\n\tMETALLIC = $metallic*orm_tex.b;\n\tROUGHNESS = $roughness*orm_tex.g;\n\tSPECULAR = 0.5;\n\tNORMAL_MAP = texture(texture_normal, base_uv).rgb;\n\tNORMAL_MAP_DEPTH = $normal;\n\tvec3 emission_tex = texture(texture_emission, base_uv).rgb;\n\tEMISSION = emission_tex*$emission_energy;\n\tAO = orm_tex.r;\n\tAO_LIGHT_AFFECT = $ao;\n$if $(connected:opacity_tex) and $(param:flags_transparent)\n\tALPHA = albedo_tex.a;\n\tALPHA_SCISSOR_THRESHOLD = 0.01;\n$fi\n$end_generate\n}\n","shortdesc":"Static PBR Material Parallax"},"type":"material_export"},{"connections":[{"from":"smooth_curvature2","from_port":0,"to":"blend","to_port":0},{"from":"gen_inputs","from_port":0,"to":"smooth_curvature2","to_port":0},{"from":"gen_inputs","from_port":0,"to":"occlusion2","to_port":0},{"from":"blend","from_port":0,"to":"gen_outputs","to_port":0},{"from":"uniform_greyscale_2","from_port":0,"to":"gen_outputs","to_port":1},{"from":"occlusion2","from_port":0,"to":"gen_outputs","to_port":3},{"from":"gen_inputs","from_port":0,"to":"invert","to_port":0},{"from":"invert","from_port":0,"to":"gen_outputs","to_port":4},{"from":"gen_inputs","from_port":0,"to":"colorize","to_port":0},{"from":"colorize","from_port":0,"to":"blend","to_port":1},{"from":"gen_inputs","from_port":0,"to":"normal_map2","to_port":0},{"from":"normal_map2","from_port":0,"to":"gen_outputs","to_port":2},{"from":"gen_inputs","from_port":0,"to":"gen_outputs","to_port":5}],"label":"Mockup","longdesc":"","name":"graph","node_position":{"x":-3531.42041015625,"y":5563.50439453125},"nodes":[{"name":"blend","node_position":{"x":-175.0,"y":-111.673553466797},"parameters":{"amount":1.0,"blend_type":4.0},"seed":18014.0,"type":"blend"},{"name":"smooth_curvature2","node_position":{"x":-426.0,"y":-205.5},"parameters":{"param0":10.0,"param1":16.0,"param2":0.51,"param3":0.2,"param4":1.0},"seed":51545.0,"type":"smooth_curvature2"},{"name":"uniform_greyscale_2","node_position":{"x":-443.0,"y":60.5},"parameters":{"color":0.08},"seed":-55961.0,"typ