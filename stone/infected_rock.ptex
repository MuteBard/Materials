)","function":true,"label":"","name":"in","type":"rgba"},{"default":"1.0","function":true,"label":"","name":"amount","type":"f"}],"instance":"vec4 $(name)_fct(vec2 uv) \n{\n\tfloat e = 1.0 / $size;\n\tvec4 result = vec4(0.0);\n\tvec4 current = $in(uv);\n\tfloat sum = 0.0;\n\t\n\t// Multiply the sigma by the strength map.\n\tfloat sigma_space = max(0.000001, $sigma_space * $amount(uv));\n\tfloat sigma_color = max(0.000001, $sigma_color * $amount(uv));\n\t\n\t// Precalculate sigma coefficients for each Gaussian function.\n\tfloat coeff_space = 1.0 / (2.0 * sigma_space * sigma_space);\n\tfloat coeff_color = 1.0 / (2.0 * sigma_color * sigma_color);\n\t\n\tfor (int x = -32; x <= 32; x++) \n\t{\n\t\tfor (int y = -32; y <= 32; y++) \n\t\t{\n\t\t\tvec2 delta_space = vec2(float(x), float(y));\n\t\t\tvec4 _sample = $in(uv + delta_space * e);\n\t\t\tvec4 delta_color = _sample - current;\n\t\t\t\n\t\t\tfloat distance_space = dot(delta_space, delta_space);\n\t\t\tfloat distance_color = dot(delta_color, delta_color);\n\t\t\t\n\t\t\tfloat weight = exp(-distance_space * coeff_space - distance_color * coeff_color);\n\t\t\t\n\t\t\tresult += _sample * weight;\n\t\t\tsum += weight;\n\t\t}\n\t}\n\t\n\treturn result / sum;\n}","name":"Filter","outputs":[{"rgba":"$(name)_fct($uv)","type":"rgba"}],"parameters":[{"default":9.0,"first":4.0,"label":"Size","last":12.0,"name":"size","type":"size"},{"control":"None","default":0.5,"label":"Sigma Space","max":32.0,"min":0.0,"name":"sigma_space","step":0.1,"type":"float"},{"control":"None","default":0.5,"label":"Sigma Color","max":1.0,"min":0.0,"name":"sigma_color","step":0.01,"type":"float"}]},"type":"shader"},{"name":"buffer_3","node_position":{"x":-338.321960449219,"y":-227.732727050781},"parameters":{"size":11.0},"seed_int":0,"type":"buffer","version":1},{"name":"buffer_4","node_position":{"x":242.678039550781,"y":-178.732727050781},"parameters":{"size":11.0},"seed_int":0,"type":"buffer","version":1}],"parameters":{"param0":11.0,"param4":5.6,"p