2] += c * c;\n        }\n    }\n\n    for (int j = 0; j <= int(radius); ++j)  {\n        for (int i = -int(radius); i <= 0; ++i)  {\n            vec3 c = $in( uv + vec2( float(i), float(j)) * offset / 100.0);\n            m[3] += c;\n            s[3] += c * c;\n        }\n    }\n\t\n    float min_sigma2 = 1e+2;\n    for (int k = 0; k < 4; ++k) {\n        m[k] /= n;\n        s[k] = abs(s[k] / n - m[k] * m[k]);\n\n        float sigma2 = s[k].r + s[k].g + s[k].b;\n        if (sigma2 < min_sigma2) {\n            min_sigma2 = sigma2;\n            color = vec3(m[k]);\n        }\n    }\n\treturn color;\n}","name":"Kuwahara Filter","outputs":[{"rgb":"$(name)_kuwahara($uv, $radius, $offset)","type":"rgb"}],"parameters":[{"control":"None","default":4,"label":"Iterations","max":10,"min":1,"name":"radius","step":1,"type":"float"},{"control":"None","default":0.01,"label":"Offset","max":1,"min":0,"name":"offset","step":0.01,"type":"float"}]}},{"name":"buffer_4","type":"buffer","parameters":{"size":11},"node_position":{"x":5666.107422,"y":-2719.869385},"seed_int":0,"version":1},{"name":"multi_warp_2","type":"multi_warp","parameters":{"param0":11,"param1":1,"param2":15,"param3":0},"node_position":{"x":-556.478882,"y":-497.095764},"seed_int":0},{"name":"fbm2","type":"fbm2","parameters":{"noise":9,"scale_x":6,"scale_y":6,"folds":0,"iterations":5,"persistence":0.5,"offset":0},"node_position":{"x":-859.51886,"y":-446.07016},"seed_int":0},{"name":"blend2_8","type":"blend2","parameters":{"blend_type1":12,"amount1":0.03},"node_position":{"x":1817.752441,"y":-305.459015},"seed_int":0,"generic_size":1},{"name":"fbm2_2","type":"fbm2","parameters":{"noise":2,"scale_x":4,"scale_y":4,"folds":0,"iterations":5,"persistence":0.5,"offset":0},"node_position":{"x":-591.640137,"y":-337.414093},"seed_int":776603072},{"name":"multi_warp_3","type":"multi_warp","parameters":{"param0":11,"param1":0.91,"param2":15,"param3":0},"node_position":{"x":-290.600128,"y":-387.134094},"seed_int":0},{"name":"blend2_10