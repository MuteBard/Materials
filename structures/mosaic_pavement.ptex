1.0) * (radius + 1.0);\n\tvec3 color = vec3(0.0);\n\t\n    vec3 m[4];\n    vec3 s[4];\n    for (int k = 0; k < 4; ++k) {\n        m[k] = vec3(0.0);\n        s[k] = vec3(0.0);\n    }\n\n    for (int j = -int(radius); j <= 0; ++j)  {\n        for (int i = -int(radius); i <= 0; ++i)  {\n            vec3 c = $in( uv + vec2( float(i), float(j)) * offset / 100.0);\n            m[0] += c;\n            s[0] += c * c;\n        }\n    }\n\t\n\tfor (int j = -int(radius); j <= 0; ++j)  {\n        for (int i = 0; i <= int(radius); ++i)  {\n            vec3 c = $in( uv + vec2( float(i), float(j)) * offset / 100.0);\n            m[1] += c;\n            s[1] += c * c;\n        }\n    }\n\n    for (int j = 0; j <= int(radius); ++j)  {\n        for (int i = 0; i <= int(radius); ++i)  {\n            vec3 c = $in( uv + vec2( float(i), float(j)) * offset / 100.0);\n            m[2] += c;\n            s[2] += c * c;\n        }\n    }\n\n    for (int j = 0; j <= int(radius); ++j)  {\n        for (int i = -int(radius); i <= 0; ++i)  {\n            vec3 c = $in( uv + vec2( float(i), float(j)) * offset / 100.0);\n            m[3] += c;\n            s[3] += c * c;\n        }\n    }\n\t\n    float min_sigma2 = 1e+2;\n    for (int k = 0; k < 4; ++k) {\n        m[k] /= n;\n        s[k] = abs(s[k] / n - m[k] * m[k]);\n\n        float sigma2 = s[k].r + s[k].g + s[k].b;\n        if (sigma2 < min_sigma2) {\n            min_sigma2 = sigma2;\n            color = vec3(m[k]);\n        }\n    }\n\treturn color;\n}","name":"Kuwahara Filter","outputs":[{"rgb":"$(name)_kuwahara($uv, $radius, $offset)","type":"rgb"}],"parameters":[{"control":"None","default":4,"label":"Iterations","max":10,"min":1,"name":"radius","step":1,"type":"float"},{"control":"None","default":0.01,"label":"Offset","max":1,"min":0,"name":"offset","step":0.01,"type":"float"}]}},{"name":"reroute_5","type":"reroute","parameters":{},"node_position":{"x":6128.18457,"y":-1399.514526},"seed_int":0},{"name":"graph_7","type":"graph","parameters"