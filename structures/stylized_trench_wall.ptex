a_space = vec2(float(x), float(y));\n\t\t\tvec4 _sample = $in(uv + delta_space * e);\n\t\t\tvec4 delta_color = _sample - current;\n\t\t\t\n\t\t\tfloat distance_space = dot(delta_space, delta_space);\n\t\t\tfloat distance_color = dot(delta_color, delta_color);\n\t\t\t\n\t\t\tfloat weight = exp(-distance_space * coeff_space - distance_color * coeff_color);\n\t\t\t\n\t\t\tresult += _sample * weight;\n\t\t\tsum += weight;\n\t\t}\n\t}\n\t\n\treturn result / sum;\n}","name":"Filter","outputs":[{"rgba":"$(name)_fct($uv)","type":"rgba"}],"parameters":[{"default":9.0,"first":4.0,"label":"Size","last":12.0,"name":"size","type":"size"},{"control":"None","default":0.5,"label":"Sigma Space","max":32.0,"min":0.0,"name":"sigma_space","step":0.1,"type":"float"},{"control":"None","default":0.5,"label":"Sigma Color","max":1.0,"min":0.0,"name":"sigma_color","step":0.01,"type":"float"}]},"type":"shader"},{"name":"buffer_3","node_position":{"x":-338.321960449219,"y":-227.732727050781},"parameters":{"size":11.0},"seed_int":0,"type":"buffer","version":1},{"name":"buffer_4","node_position":{"x":242.678039550781,"y":-178.732727050781},"parameters":{"size":11.0},"seed_int":0,"type":"buffer","version":1}],"parameters":{"param0":11.0,"param4":33.0,"param5":0.46},"seed":35292.0,"shortdesc":"Bilateral Filter","type":"graph"},{"name":"invert_8","node_position":{"x":-620.0,"y":1660.0},"parameters":{},"seed_int":0,"type":"invert"},{"name":"fbm3_3","node_position":{"x":-460.0,"y":1840.0},"parameters":{"folds":0.0,"iterations":1.0,"noise":1.0,"offset":0.0,"persistence":0.5,"scale_x":6.0,"scale_y":6.0},"seed_int":0,"type":"fbm3"},{"generic_size":1,"name":"blend2_29","node_position":{"x":-160.0,"y":1680.0},"parameters":{"amount1":1.0,"blend_type1":0.0},"seed_int":0,"type":"blend2"},{"connections":[{"from":"gen_inputs","from_port":1,"to":"gaussian_blur_x_2","to_port":1},{"from":"gen_inputs","from_port":0,"to":"buffer_3","to_port":0},{"from":"buffer_3","from_port":0,"to":"gaussian_blur_x_2","to_port":0},