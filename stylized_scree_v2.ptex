me":"math_7","node_position":{"x":2822.56372070313,"y":-345.860107421875},"parameters":{"clamp":false,"default_in1":0.0,"default_in2":0.0,"op":15.0},"seed_int":0,"type":"math"},{"name":"gen_inputs","node_position":{"x":2026.56372070313,"y":-652.360107421875},"parameters":{},"ports":[{"longdesc":"","name":"unnamed","shortdesc":"Background","type":"rgba"},{"longdesc":"","name":"unnamed","shortdesc":"Foreground","type":"rgba"}],"seed_int":0,"type":"ios"},{"name":"gen_outputs","node_position":{"x":3265.56372070313,"y":-652.360107421875},"parameters":{},"ports":[{"longdesc":"","name":"unnamed","shortdesc":"Output","type":"rgba"},{"longdesc":"","name":"unnamed","shortdesc":"Mask","type":"rgba"}],"seed_int":0,"type":"ios"},{"name":"gen_parameters","node_position":{"x":2697.56372070313,"y":-1047.86010742188},"parameters":{"param0":1.0,"param1":0.0},"seed_int":0,"type":"remote","widgets":[{"label":"Opacity","linked_widgets":[{"node":"math_2","widget":"default_in2"}],"name":"param0","type":"linked_control"},{"label":"Adjust","linked_widgets":[{"node":"math","widget":"default_in2"}],"name":"param1","type":"linked_control"}]},{"name":"math","node_position":{"x":2568.263671875,"y":-349.16015625},"parameters":{"clamp":false,"default_in1":0.0,"default_in2":0.0,"op":0.0},"seed_int":0,"type":"math"},{"name":"math_2","node_position":{"x":2517.03393554688,"y":-605.472045898438},"parameters":{"clamp":false,"default_in1":0.0,"default_in2":1.0,"op":2.0},"seed_int":0,"type":"math"}],"parameters":{"param0":1.0,"param1":0.0},"seed_int":0,"shortdesc":"","type":"graph"},{"name":"buffer_8","node_position":{"x":-5704.8232421875,"y":-2498.490234375},"parameters":{"size":11.0},"seed_int":0,"type":"buffer","version":1},{"name":"splatter_3","node_position":{"x":-3868.86083984375,"y":-509.299163818359},"parameters":{"count":28.0,"inputs":0.0,"mode":0.0,"rnd_count":5.0,"rnd_scale_x":0.25,"rnd_scale_y":0.14,"rotate":180.0,"scale":0.18,"scale_x":0.28,"scale_y":0.22,"start_rot":43.1,"value":0.52,"variations":true},"seed_int":4109283584,"shader_model":{"code":"vec3 $(name_uv)_instance_uv = vec3(0.0);\nvec4 $(name_uv)_rch = splatter_$(name)($uv, int($count + float($seed) * $rnd_count), $(name_uv)_instance_uv, vec2(float($seed)));","global":"","includes":["custom_uv"],"inputs":[{"default":"0.0","function":true,"label":"","longdesc":"The input image or atlas of 4 or 16 input images","name":"in","shortdesc":"Input","type":"f"},{"default":"1.0","function":true,"label":"","longdesc":"The mask applied to the pattern","name":"mask","shortdesc":"Mask","type":"f"},{"default":"1.0","function":true,"label":"3:","name":"warp","shortdesc":"Warp Map","type":"f"},{"default":"1.0","function":true,"label":"4:","name":"sc_x","shortdesc":"Scale X Map","type":"f"},{"default":"1.0","function":true,"label":"5:","name":"sc_y","shortdesc":"Scale Y Map","type":"f"},{"default":"1.0","function":true,"label":"6:","name":"rot","shortdesc":"Rotation Map","type":"f"},{"default":"1.0","function":true,"label":"7:","name":"rot_rnd","shortdesc":"RotationRnd Map","type":"f"},{"default":"1.0","function":true,"label":"9:","name":"rnd_val","shortdesc":"ValueRnd Map","type":"f"}],"instance":"vec4 splatter_$(name)(vec2 uv, int count, inout vec3 instance_uv, vec2 seed) {\n\tfloat c = 0.0;\n\tvec3 rc = vec3(0.0);\n\tvec2 pos = vec2(0.0);\n\tvec3 rc1;\n\tfor (int i = 0; i < count; ++i) {\n\t\tseed = rand2(seed);\n\t\trc1 = rand3(seed);\n\t\tfloat mask = $mask(fract(seed+vec2(0.5)));\n\t\tif (mask > 0.01) {\n\t\t\tvec2 pv = fract(uv - seed)-vec2(0.5);\n\t\t\tpos = uv - pv;\n\t\t\tseed = rand2(seed);\n\t\t\tfloat angle = (seed.x * 2.0 - 1.0) * $rotate * 0.01745329251 * $rot_rnd(pos);\n\t\t\t//float angle_start = $start_rot * 0.01745329251;\n\t\t\tfloat angle_start = (($rot(pos) * 180.0) + ($warp(uv) * 180.0) + $start_rot) * 0.01745329251;\n\t\t\tfloat ca = cos(angle + angle_start);\n\t\t\tfloat sa = sin(angle + angle_start);\n\t\t\tpv = vec2(ca*pv.x+sa*pv.y, -sa*pv.x+ca*pv.y);\n\t\t\tpv *= (seed.y-0.5)*2.0*$scale+1.0;\n\t\t\tseed = rand2(seed);\n\t\t\tpv *= vec2(1,(seed.y-0.5)*1.5*$rnd_scale_y+1.0);\n\t\t\tseed = rand2(seed);\n\t\t\tpv *= vec2((seed.y-0.5)*1.5*$rnd_scale_x+1.0, 1);\n\t\t\t//pv /= vec2($scale_x, $scale_y);\n\t\t\tpv /= vec2($scale_x * $sc_x(pos), $scale_y * $sc_y(pos));\n\t\t\tpv += vec2(0.5);\n\t\t\tseed = rand2(seed);\n\t\t\t\n\t\t\tvec2 clamped_pv = clamp(pv, vec2(0.0), vec2(1.0));\n\t\t\tif (pv.x != clamped_pv.x || pv.y != clamped_pv.y) {\n\t\t\t\tcontinue;\n\t\t\t}\n\t\t\tvec2 full_uv = pv;\n\t\t\tpv = get_from_tileset($inputs, seed.x, pv);\n\t\t\t//float c1 = $in.variation(pv, $variations ? seed.x : 0.0)*mask*(1.0-($value*$rnd_val(pos))*seed.x);\n\t\t\tfloat c1 = $in.variation(pv, $variations ? seed.x : 0.0)*mask*(1.0-($value*$rnd_val(pos))*seed.x);\n\t\t\t\n\t\t\tif ($mode == 0) {\n\t\t\t\t\tc = max(c, c1);\n\t\t\t\t\t}\n\t\t\t\telse if ($mode == 1 || $mode == 2) {\n\t\t\t\t\tc = c + c1;\n\t\t\t\t\t}\n\t\t\t\telse {\n\t\t\t\t\tc = abs(c - c1);\n\t\t\t\t\t}\n\t\t\t\t\n\t\t\t\tif ($mode == 2 || $mode == 4) {\n\t\t\t\t\tc = clamp(c, 0.0, 1.0);\n\t\t\t\t\t}\n\t\t\t\n\t\t\trc = mix(rc, rc1, step(c, c1));\n\t\t\tinstance_uv = mix(instance_uv, vec3(full_uv, seed.x), step(c, c1));\n\t\t}\n\t}\n\treturn vec4(rc, c);\n}\n","longdesc":"Spreads several occurences of an input image randomly.\nWith support for a start rotation and random X and Y scale values.\n\nBased on the original splatter node, extended by rubberduck","name":"Splatter++","outputs":[{"f":"$(name_uv)_rch.a","longdesc":"Shows the generated pattern","shortdesc":"Output","type":"f"},{"longdesc":"Shows a random color for each instance of the input image","rgb":"$(name_uv)_rch.rgb","shortdesc":"Instance map","type":"rgb"},{"longdesc":"Per instance UVs. Can be used with Custom UV node.","rgb":"$(name_uv)_instance_uv","shortdesc":"Instance UV","type":"rgb"}],"parameters":[{"control":"None","default":10.0,"label":"Count","longdesc":"The minimum number of occurences of the input image","max":100.0,"min":1.0,"name":"count","shortdesc":"Count","step":1.0,"type":"float"},{"control":"None","default":1.0,"label":"Rnd Count","longdesc":"Add a random number of instances per seed (total = count + random count)","max":100.0,"min":0.0,"name":"rnd_count","shortdesc":"Random Count","step":1.0,"type":"float"},{"default":0.0,"label":"Inputs","longdesc":"The input type of the node:\n- 1: single image\n- 4: atlas of 4 images\n- 16: atlas of 16 images\nAtlases can be created using the Tile2x2 node.","name":"inputs","shortdesc":"Input","type":"enum","values":[{"name":"1","value":" 1.0"},{"name":"4","value":"2.0"},{"name":"16","value":"4.0"}]},{"control":"None","default":1.0,"label":"Scale X","longdesc":"The scale of input images on the X axis","max":2.0,"min":0.0,"name":"scale_x","shortdesc":"Scale.x","step":0.01,"type":"float"},{"control":"None","default":1.0,"label":"Scale Y","longdesc":"The scale of input images on the Y axis","max":2.0,"min":0.0,"name":"scale_y","shortdesc":"Scale.y","step":0.01,"type":"float"},{"control":"None","default":0.0,"label":"Start Rotation","longdesc":"The start rotation for all instances","max":180.0,"min":0.0,"name":"start_rot","shortdesc":"Start rotation","step":0.1,"type":"float"},{"control":"None","default":0.0,"label":"Rnd Rotate","longdesc":"The random rotation applied to each image instance","max":180.0,"min":0.0,"name":"rotate","shortdesc":"RndRotate","step":0.1,"type":"float"},{"control":"None","default":0.0,"label":"Rnd Scale","longdesc":"The random scale applied to each image instance","max":1.0,"min":0.0,"name":"scale","shortdesc":"RndScale","step":0.01,"type":"float"},{"control":"None","default":0.5,"label":"Rnd Value","longdesc":"The random greyscale value applied to each image instance","max":1.0,"min":0.0,"name":"value","shortdesc":"RndValue","step":0.01,"type":"float"},{"control":"None","default":1.0,"label":"Rnd Scale X","longdesc":"The random scale of input images on the X axis","max":2.0,"min":0.0,"name":"rnd_scale_x","shortdesc":