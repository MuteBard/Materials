","from_port":0,"to":"fbm3_4","to_port":0},{"from":"reroute_21","from_port":0,"to":"fbm3_5","to_port":0}],"label":"Grunge Dirty Rough","longdesc":"Created by rubberduck","name":"graph_43","node_position":{"x":2433.94018554688,"y":-3041.44750976563},"nodes":[{"name":"colorize","node_position":{"x":1260.0,"y":-500.0},"parameters":{"gradient":{"interpolation":1,"points":[{"a":1.0,"b":0.05078125,"g":0.05078125,"pos":0.255378516944679,"r":0.05078125},{"a":1.0,"b":0.7890625,"g":0.7890625,"pos":0.656730033255912,"r":0.7890625}],"type":"Gradient"}},"seed_int":0,"type":"colorize"},{"name":"colorize_2","node_position":{"x":1280.0,"y":-400.0},"parameters":{"gradient":{"interpolation":1,"points":[{"a":1.0,"b":0.0,"g":0.0,"pos":0.0,"r":0.0},{"a":1.0,"b":0.48046875,"g":0.48046875,"pos":0.754186681798987,"r":0.48046875}],"type":"Gradient"}},"seed_int":0,"type":"colorize"},{"name":"shard_fbm_3","node_position":{"x":1540.0,"y":-540.0},"parameters":{"clamp":false,"folds":0.0,"iter":3.0,"off":0.85,"per":0.83,"sharp":0.76,"straighten":0.0,"sx":7.0,"sy":3.0,"var":0.0,"warp":1.9},"seed_int":1761235712,"shader_model":{"code":"","global":"// Adapted from https://www.shadertoy.com/view/dlKyWw by @ENDESGA\n\nvec3 hash(vec3 p)\n{\n\t\n\tp = vec3(dot(p, vec3(127.1, 311.7, 74.7)),dot(p, vec3(269.5,183.3,246.1)), dot(p, vec3(113.5, 271.9, 124.6)));\n\tp = fract(sin(p) * 43758.5453123);\n\treturn p;\n}\n\nfloat shard_noise(vec3 p, vec3 size, float sharpness, float seed, float var, float straighten, float bend) {\n\tvec3 ip = floor(p);\n\tvec3 fp = fract(p);\n\n\tfloat v = 0.0, t = 0.0;\n\t\n\tfor (int z = -1; z <= 1; z++) {\n\t\tfor (int y = -2; y <= 2; y++) {\n\t\t\tfor (int x = -2; x <= 2; x++) {\n\t\t\t\n\t\t\t\tvec3 o = vec3(float(x), float(y), float(z));\n\t\t\t\tvec3 io = mod(ip + o, size);\n\t\t\t\tvec3 h = hash(io + seed);\n\t\t\t\tvec3 r = fp - (o + h);\n\n\t\t\t\tfloat w = exp2(-6.283185*dot(r , r));\n\t\t\t\t// tanh deconstruction and optimization by @Xor\n\t\n\t\t\t\tfloat s = sharpness * dot(r+(w * bend) + (straighten * r.y) , hash(io + vec3(11, 31, 47)) - 0.5);\n\t\t\t\tv += w * s*inversesqrt(1.0+s*s);\n\t\t\t\tt += w;\n\t\t\t}\n\t\t}\n\t}\n\treturn ((v  / t  *  (1.0 + t * var - (var * 6.0 * v))) * 0.5) + 0.5;\n}\n\nfloat fbm_shard(vec3 coord, vec3 size, int folds, int octaves, float persistence, float sharpness, float seed, float var, float straighten, float bend, bool clamp_mode) {\n\tfloat normalize_factor = 0.0;\n\tfloat value = 0.0;\n\tfloat scale = 1.0;\n\tfloat result = 0.0;\n\tfor (int i = 0; i < octaves; i++) {\n\t\tfloat noise = shard_noise(coord*size, size, sharpness, seed, var, straighten, bend);\n\t\t\n\t\t\t\n\t\tfor (int f = 0; f < folds; ++f) {\n\t\t\tnoise = abs(2.0*noise-1.0);\n\t\t}\n\t\tvalue += noise * scale;\n\t\tnormalize_factor += scale;\n\t\tsize *= 2.0;\n\t\tscale *= persistence;\n\t\t\n\t\tresult = value / normalize_factor;\n\t\t\n\t\tif (clamp_mode)\n\t\t{\n\t\t\tresult = clamp(result, 0.0, 1.0);\n\t\t}\n\t}\n\treturn result;\n}","inputs":[{"default":"$sharp","label":"1:","longdesc":"Map that affects the sharpness parameter","name":"sharp_in","shortdesc":"Sharpness Map","type":"f"},{"default":"$off","label":"7:","longdesc":"An optional input to drive the offset","name":"offset_in","shortdesc":"Offset Input","type":"f"},{"default":"1.0","label":"9:","longdesc":"controls the straighten effect","name":"str_in","shortdesc":"Straighten Map","type":"f"},{"default":"1.0","label":"10:","longdesc":"controls the circle warp effect","name":"circle_in","shortdesc":"Circle Map","type":"f"}],"instance":"","longdesc":"A modified version of the existing shard noise.\n\nCreated by rubberduck","name":"ShardFBM++","outputs":[{"f":"fbm_shard(vec3($uv,$offset_in($uv)),vec3($sx,$sy,1.0),int($folds),int($iter),$per,pow(2,$sharp_in($uv)*$sharp*8.0),$seed, $var, $str_in($uv)*$straighten, $circle_in($uv)*$warp, $clamp)","longdesc":"Greyscale image of the generated noise","shortdesc":"Output","type":"f"}],"parameters":[{"control":"None","default":0.7,"label":"Sharpness","longdesc":"Sharpness of the noise","max":1.0,"min":0.0,"name":"sharp","shortdesc":"Sharpness","step":0.01,"type":"float"},{"control":"None","default":7.0,"label":"Scale X","longdesc":"Scale of the first octave along the X axis","max":32.0,"min":1.0,"name":"sx","shortdesc":"Scale.x","step":1.0,"type":"float"},{"control":"None","default":7.0,"label":"Scale Y","longdesc":"Scale of the first octave along the Y axis","max":32.0,"min":1.0,"name":"sy","shortdesc":"Scale.y","step":1.0,"type":"float"},{"control":"None","default":0.0,"label":"Folds","longdesc":"Number of times the noise is folded","max":5.0,"min":0.0,"name":"folds","shortdesc":"Folds","step":1.0,"type":"float"},{"control":"None","default":4.0,"label":"Iterations","longdesc":"Number of noise octaves","max":8.0,"min":1.0,"name":"iter","shortdesc":"Octaves","step":1.0,"type":"float"},{"control":"None","default":0.5,"label":"Persistence","longdesc":"Persistence between two consecutive octaves","max":1.0,"min":0.0,"name":"per","shortdesc":"Persistence","step":0.01,"type":"float"},{"control":"None","default":0.0,"label":"Offset","longdesc":"Offsets the points of the noise, can be used to animate the noise with \"$time\"","max":1.0,"min":0.0,"name":"off","shortdesc":"Offset","step":0.01,"type":"float"},{"control":"None","default":0.0,"label":"Variation","max":5.0,"min":-5.0,"name":"var","step":0.01,"type":"float"},{"control":"None","default":0.0,"label":"Straighten","longdesc":"straightens the shards horizontally","max":10.0,"min":0.0,"name":"straighten","shortdesc":"Straighten","step":0.01,"type":"float"},{"control":"None","default":0.5,"label":"Circle Warp","max":10.0,"min":0.0,"name":"warp","step":0.1,"type":"float"},{"default":true,"label":"Clamp","name":"clamp","type":"boolean"}],"shortdesc":"Fractional Brownian Motion Noise ++"},"type":"shader"},{"name":"reroute_3","node_position":{"x":2211.51293945313,"y":-1101.15759277344},"parameters":{"preview":0.0},"seed_int":0,"type":"rerout