:{"amount1":0.61,"blend_type1":4.0},"seed_int":0,"type":"blend2"},{"generic_size":1,"name":"blend2_4","node_position":{"x":3256.87573242188,"y":-697.115478515625},"parameters":{"amount1":0.48,"blend_type1":4.0},"seed_int":0,"type":"blend2"},{"name":"reroute_2","node_position":{"x":2984.03442382813,"y":-581.039367675781},"parameters":{"preview":0.0},"seed_int":0,"type":"reroute"},{"name":"colorize_3","node_position":{"x":1575.12365722656,"y":-1161.68701171875},"parameters":{"gradient":{"interpolation":1,"points":[{"a":1.0,"b":0.22265625,"g":0.22265625,"pos":0.0,"r":0.22265625},{"a":1.0,"b":1.0,"g":1.0,"pos":1.0,"r":1.0}],"type":"Gradient"}},"seed_int":0,"type":"colorize"},{"name":"combine","node_position":{"x":2558.63159179688,"y":-881.404174804688},"parameters":{},"seed_int":0,"type":"combine"},{"name":"791_3","node_position":{"x":3205.00390625,"y":-1033.94030761719},"parameters":{"blend_type":0.0,"m_opacity":0.8,"m_smooth":0.5,"m_step":0.607871235280797,"warp_strength":0.6,"warp_x":0.0,"warp_y":0.7},"seed":44788.0,"shader_model":{"code":"vec2 $(name_uv)_warp1 = $uv + $warp_strength *  vec2($warp_x*($warp($uv).r-0.5),  -$warp_y*($warp($uv).g)-0.5);\nvec2 $(name_uv)_warp2 = $uv - $warp_strength *  vec2($warp_x*($warp($uv).g-0.5),  -$warp_y*($warp($uv).r)-0.5);\n\nfloat $(name_uv)_a1 = $m_opacity*smoothstep($m_step-$m_smooth,  $m_step+$m_smooth,  $warp($uv).b);\nfloat $(name_uv)_a2 = $m_opacity*smoothstep($m_step-$m_smooth,  $m_step+$m_smooth,  $warp($uv).a);\n\n","global":"","includes":["blend"],"inputs":[{"default":"0.0","label":"","name":"in_1","shortdesc":"Input 1","type":"rgb"},{"default":"0.0","label":"","name":"in_2","shortdesc":"Input 2","type":"rgb"},{"default":"0.0","label":"","longdesc":"A Warp image combines UV warping and blending.\n\nR,G\t\t\nare mapped to a vector, which warps UV coords.\n\nB,A\t\t\nare used to blend both input images. How they are blended is controlled by a smoothstep, which could be adjust with \"Step\" and \"Smooth\".","name":"warp","shortdesc":"Warp","type":"rgba"}],"instance":"","longdesc":"Mingle node with one output.\nBasic node which could be used to create grunge images.\n\nMingle combines a warp operation and a blend operation. The blend operation is controlled by a step operation and an opacity value.\n\nCreated by leonard7e.","name":"Mingle Extended","outputs":[{"rgb":"blend_$blend_type( $uv,  $in_1($(name_uv)_warp1),  $in_2($(name_uv)_warp2),  $(name_uv)_a1 )","shortdesc":"Output","type":"rgb"},{"rgb":"blend_$blend_type( $uv,  $in_1($(name_uv)_warp2),  $in_2($(name_uv)_warp1),  $(name_uv)_a2 )","type":"rgb"}],"parameters":[{"default":0.0,"label":"","longdesc":"Specify method how you like to warp input images.","name":"blend_type","shortdesc":"Blend Type","type":"enum","values":[{"name":"Normal","value":"normal"},{"name":"Dissolve","value":"dissolve"},{"name":"Multiply","value":"multiply"},{"name":"Screen","value":"screen"},{"name":"Overlay","value":"overlay"},{"name":"Hard Light","value":"hard_light"},{"name":"Soft Light","value":"soft_light"},{"name":"Burn","value":"burn"},{"name":"Dodge","value":"dodge"},{"name":"Lighten","value":"lighten"},{"name":"Darken","value":"darken"},{"name":"Difference","value":"difference"}]},{"control":"None","default":1.0,"label":"Opacity","longdesc":"The  amount of opacity used to blend input 1 over Input 2. \nDefaults to 1.","max":1.0,"min":0.0,"name":"m_opacity","shortdesc":"Opacity","step":0.1,"type":"float"},{"control":"None","default":0.5,"label":"Step","max":1.0,"min":0.0,"name":"m_step","shortdesc":"Step","step":0.0,"type":"float"},{"control":"None","default":0.5,"label":"Smooth","max":1.0,"min":0.0,"name":"m_smooth","shortdesc":"Smooth","step":0.0,"type":"float"},{"control":"P1.x","default":0.5,"label":"Warp X","max":10.0,"min":0.0,"name":"warp_x","step":0.1,"type":"float"},{"control":"P1.y","default":0.5,"label":"Warp Y","max":10.0,"min":0.0,"name":"warp_y","step":0.1,"type":"float"},{"control":"None","default":1.0,"label":"Warp Strength","max"