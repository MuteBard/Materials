"overlap":3.0,"rnd_scale_x":0.15,"rnd_scale_y":0.23,"rotate":7.1,"scale":0.45,"scale_x":0.61,"scale_y":0.59,"start_rot":8.5,"tx":9.0,"ty":19.0,"value":1.95,"variations":true},"seed_int":3836420096,"shader_model":{"code":"vec3 $(name_uv)_instance_uv = vec3(0.0);\nvec4 $(name_uv)_rch = tiler_$(name)($uv, vec2($tx, $ty), int($overlap), $(name_uv)_instance_uv, vec2(float($seed)));","global":"","includes":["custom_uv"],"inputs":[{"default":"0.0","function":true,"label":"","longdesc":"The input image or atlas of 4 or 16 input images","name":"in","shortdesc":"Input","type":"f"},{"default":"1.0","function":true,"label":"","longdesc":"The mask applied to the pattern","name":"mask","shortdesc":"Mask","type":"f"},{"default":"0.0","function":true,"label":"3:","name":"warp","shortdesc":"Warp Map","type":"f"},{"default":"1.0","function":true,"label":"5:","name":"sc_x","shortdesc":"Scale X Map","type":"f"},{"default":"1.0","function":true,"label":"6:","name":"sc_y","shortdesc":"Scale Y Map","type":"f"},{"default":"1.0","function":true,"label":"12:","name":"rot","shortdesc":"Rotation Map","type":"f"},{"default":"1.0","function":true,"label":"13:","name":"rot_rnd","shortdesc":"RotationRnd Map","type":"f"},{"default":"1.0","function":true,"label":"14:","name":"rnd_val","shortdesc":"ValueRnd Map","type":"f"}],"instance":"vec4 tiler_$(name)(vec2 uv, vec2 tile, int overlap, inout vec3 instance_uv, vec2 _seed) {\n\tfloat c = 0.0;\n\tvec3 rc = vec3(0.0);\n\tvec3 rc1;\n\tfor (int dx = -overlap; dx <= overlap; ++dx) {\n\t\tfor (int dy = -overlap; dy <= overlap; ++dy) {\n\t\t\tvec2 pos = uv*tile+vec2(float(dx), float(dy)); pos = fract((floor(mod(pos, tile))+vec2(0.5))/tile)-vec2(0.5);\n\t\t\tvec2 seed = rand2(pos+_seed);\n\t\t\trc1 = rand3(seed);\n\t\t\tpos = fract(pos+vec2($fixed_offset/tile.x, 0.0)*floor(mod(pos.y*tile.y, 2.0))+$offset*seed/tile);\n\t\t\tfloat mask = $mask(fract(pos+vec2(0.5)));\n\t\t\tif (mask > 0.01) {\n\t\t\t\tvec2 pv = fract(uv - pos)-vec2(0.5);\n\t\t\t\tseed = rand2(seed);\n\t\t\t\tfloat angle = (seed.x * 2.0 - 1.0) * $rotate * 0.01745329251 * $rot_rnd(pos);\n\t\t\t\tfloat angle_start = (($rot(pos) * 180.0) + ($warp(uv) * 180.0) + $start_rot) * 0.01745329251;\n\t\t\t\tfloat ca = cos(angle + angle_start);\n\t\t\t\tfloat sa = sin(angle + angle_start);\n\t\t\t\tpv = vec2(ca*pv.x+sa*pv.y, -sa*pv.x+ca*pv.y);\n\t\t\t\tpv *= (seed.y-0.5)*2.0*$scale+1.0;\n\t\t\t\tseed = rand2(seed);\n\t\t\t\tpv *= vec2(1,(seed.y-0.5)*1.5*$rnd_scale_y+1.0);\n\t\t\t\tseed = rand2(seed);\n\t\t\t\tpv *= vec2((seed.y-0.5)*1.5*$rnd_scale_x+1.0, 1);\n\t\t\t\tpv /= vec2($scale_x * $sc_x(pos), $scale_y * $sc_y(pos));\n\t\t\t\tpv += vec2(0.5);\n\t\t\t\tseed = rand2(seed);\n\t\t\t\tvec2 clamped_pv = clamp(pv, vec2(0.0), vec2(1.0));\n\t\t\t\tif (pv.x != clamped_pv.x || pv.y != clamped_pv.y) {\n\t\t\t\t\tcontinue;\n\t\t\t\t}\n\t\t\t\tvec2 full_uv = pv;\n\t\t\t\tpv = get_from_tileset($inputs, seed.x, pv);\n\t\t\t\tfloat c1 = $in.variation(pv, $variations ? seed.x : 0.0)*mask*(1.0-($value*$rnd_val(pos))*seed.x);\n\t\t\t\t\n\t\t\t\t// Default\n\t\t\t\tif ($mode == 0) {\n\t\t\t\t\tc = max(c, c1);\n\t\t\t\t\t}\n\t\t\t\telse if ($mode == 1 || $mode == 2) {\n\t\t\t\t\tc = c + c1;\n\t\t\t\t\t}\n\t\t\t\telse {\n\t\t\t\t\tc = abs(c - c1);\n\t\t\t\t\t}\n\t\t\t\t\n\t\t\t\tif ($mode == 2 || $mode == 4) {\n\t\t\t\t\tc = clamp(c, 0.0, 1.0);\n\t\t\t\t\t}\n\t\t\t\t\n\t\t\t\trc = mix(rc, rc1, step(c, c1));\n\t\t\t\tinstance_uv = mix(instance_uv, vec3(full_uv, seed.x), step(c, c1));\n\t\t\t}\n\t\t}\n\t}\n\treturn vec4(rc, c);\n}","longdesc":"Tiles several occurences of an input image while adding randomness.","name":"Tiler++","outputs":[{"f":"$(name_uv)_rch.a","longdesc":"Shows the generated pattern","shortdesc":"Output","type":"f"},{"longdesc":"Shows a random color for each instance of the input image","rgb":"$(name_uv)_rch.rgb","shortdesc":"Instance map","type":"rgb"},{"longdesc":"Per instance UVs. Can be used with Custom UV node.","rgb":"$(name_uv)_instance_uv","shortdesc":"Instance UV","type":"rgb"}],"parameters":[{"control":"None","default":4.0,"label":"Tile X","longdesc":"The number of columns of the tiles pattern","max":64.0,"min":1.0,"name":"tx","shortdesc":"Tile.x","step":1.0,"type":"float"},{"control":"None","default":4.0,"label":"Tile Y","longdesc":"The number of rows of the tiles pattern","max":64.0,"min":1.0,"name":"ty","shortdesc":"Tile.y","step":1.0,"type":"float"},{"control":"None","default":1.0,"label":"Overlap","longdesc":"The number of neighbour tiles an instance of the input image can overlap. Set this parameter to the lowest value that generates the expected result (where all instances are fully visible) to improve performance.","max":5.0,"min":0.0,"name":"overlap","shortdesc":"Overlap","step":1.0,"type":"float"},{"default":0.0,"label":"Inputs","longdesc":"The input type of the node:\n- 1: single image\n- 4: atlas of 4 images\n- 16: atlas of 16 images\nAtlases can be created using the Tile2x2 node.","name":"inputs","shortdesc":"Input","type":"enum","values":[{"name":"1","value":" 1.0"},{"name":"4","value":"2.0"},{"name":"16","value":"4.0"}]},{"control":"None","default":1.0,"label":"Scale X","longdesc":"The scale of input images on the X axis","max":2.0,"min":0.0,"name":"scale_x","shortdesc":"Scale.x","step":0.01,"type":"float"},{"control":"None","default":1.0,"label":"Scale Y","longdesc":"The scale of input images on the Y axis","max":2.0,"min":0.0,"name":"scale_y","shortdesc":"Scale.y","step":0.01,"type":"float"},{"control":"None","default":0.0,"label":"Rnd Scale","max":1.0,"min":0.0,"name":"scale","step":0.01,"type":"float"},{"control":"None","default":0.0,"label":"Rnd Scale X","max":1.0,"min":0.0,"name":"rnd_scale_x","step":0.01,"type":"float"},{"control":"None","default":0.0,"label":"Rnd Scale Y","max":1.0,"min":0.0,"name":"rnd_scale_y","step":0.01,"type":"float"},{"control":"None","default":0.5,"label":"Fixed Offset","longdesc":"The relative offset of odd rows","max":1.0,"min":0.0,"name":"fixed_offset","shortdesc":"Fixe